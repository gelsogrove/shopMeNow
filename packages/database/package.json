{
  "name": "@echatbot/database",
  "version": "1.0.0",
  "description": "Shared Prisma database client for eChatbot",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./data/*": "./prisma/data/*.ts",
    "./data/defaultFAQs": "./prisma/data/defaultFAQs.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:reset": "dotenv -e ../../.env -- ts-node scripts/safe-reset.ts",
    "migrate:reset:force": "dotenv -e ../../.env -- prisma migrate reset --force",
    "seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "update:prompts": "dotenv -e ../../.env -- ts-node scripts/update-prompts.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "check:env": "dotenv -e ../../.env -- ts-node scripts/check-env-safety.ts",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "bcrypt": "^5.1.1",
    "dotenv-cli": "^7.3.0",
    "jest": "^29.7.0",
    "prisma": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
