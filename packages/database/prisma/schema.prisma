generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id                        String    @id @default(cuid())
  name                      String
  slug                      String    @unique
  whatsappPhoneNumber       String?
  whatsappApiKey            String?
  whatsappPhoneNumberId     String?
  whatsappVerifyToken       String?
  notificationEmail         String?
  webhookUrl                String?
  language                  String    @default("ENG")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?
  currency                  String    @default("USD")
  channelStatus             Boolean   @default(true) // true = channel active (queue enabled), false = channel disabled
  description               String?
  messageLimit              Int       @default(50)
  url                       String?
  welcomeMessage            String?   @default("Welcome! I'm {{chatbotName}}, your digital assistant. I can help you discover Italian gourmet products, answer questions, and manage orders. How can I help you today?") @db.Text
  wipMessage                String?   @default("Work in progress. Please contact us later.") @db.Text
  afterRegistrationMessages String?   @default("Thank you for registering, {{customerName}}! How can I help you today? Would you like to see your orders? The offers? Or do you need other information?") @db.Text
  debugMode                 Boolean   @default(true)
  apiKey                    String?
  metadata                  Json?
  allowedExternalLinks      String[]  @default([]) // Security Agent: allowed external domains (e.g., ["shopme.com", "stripe.com"])
  logoUrl                   String? // Channel logo URL (circular display) - for admin UI
  logoKey                   String? // 💾 Storage key for cleanup
  websiteUrl                String?   @db.Text // Custom domain/base URL for this workspace (e.g., "https://shop.acme.com")

  // 🆕 Web Widget Configuration
  widgetLogoUrl      String? // Widget logo URL (for customer-facing chat widget)
  widgetLogoKey      String? // 💾 Storage key for cleanup
  widgetTitle        String? // Custom title for chat widget (default: workspace name)
  widgetLanguage     String? @default("it") // Default language: it, en, es, pt
  widgetPrimaryColor String? @default("#22c55e") // Primary color in hex format
  widgetTextColor    String? @default("#0f172a") // Text color for widget accents (links, labels)
  widgetIcon         String? @default("chat") // Icon for widget trigger button

  // 🆕 Channel Configuration (from Wizard - Feature 199)
  channelType                       ChannelType @default(WHATSAPP) // WhatsApp or Widget
  enableWhatsapp                    Boolean     @default(true)
  enableWidget                      Boolean     @default(false)
  sellsProductsAndServices          Boolean     @default(true) // Does this channel sell products/services? (enables E-commerce menu)
  hasSalesAgents                    Boolean     @default(false) // Has sales team for customer assignment?
  hasHumanSupport                   Boolean     @default(true) // Can customers request human support?
  humanSupportInstructions          String?     @db.Text // Instructions for human support requests
  frustrationEscalationInstructions String?     @db.Text // 🆕 Feature 203: Custom triggers for when chatbot should call operator (panic/frustration cases)
  operatorContactMethod             String?     @default("email") // 'email' | 'whatsapp'
  operatorEmail                     String? // Email for human support notifications
  operatorWhatsappNumber            String? // WhatsApp number for human support (if method='whatsapp')
  toneOfVoice                       String?     @default("friendly") // 'formal' | 'friendly' | 'professional' | 'casual'
  botIdentityResponse               String?     @db.Text // Response when customer asks "Who are you?"
  customAiRules                     String?     @db.Text // Custom AI rules/instructions that override default behavior
  address                           String?     @db.Text // Physical address/location for "where are you?" questions
  chatbotName                       String?     @default("Assistente") // 🆕 Custom name for the chatbot (e.g., "Sofia", "Marco", "Assistant")
  businessType                      String?     @default("other") // 🆕 Business sector for LLM context (e.g., "food", "fashion", "tech")
  registrationPage                  String?     @db.Text // 🆕 Custom registration page URL for customers (used by LINK_REGISTRATION)
  requireManualApproval             Boolean     @default(false) // 🆕 If true, new customers go to PENDING_APPROVAL after registration (admin must activate)
  approvalMessage                   String?     @db.Text // 🆕 Message sent to customer when admin approves their registration (default: "🎉 Your registration has been approved!")

  // �🆕 Translation Settings (Feature: Configurable Translation Layer)
  translateProductNames  Boolean @default(false) // Translate product names to customer language (false = preserve original, e.g., "Pecorino Romano")
  translateCategoryNames Boolean @default(false) // Translate category names to customer language
  translateServiceNames  Boolean @default(true) // Translate service names (default true as they're usually generic)
  catalogBaseLanguage    String  @default("it") // Base language of catalog (ISO 639-1: "it", "en", "es", "pt", "de", "fr")

  // Team management: ownerId groups all channels belonging to same owner
  ownerId String?
  owner   User?   @relation("OwnedWorkspaces", fields: [ownerId], references: [id])

  // ⚠️ DEPRECATED: Billing fields - moving to User model (Feature 198)
  // These fields will be removed after data migration is complete
  // Use User.planType, User.creditBalance, etc. instead
  planType                 PlanType           @default(FREE_TRIAL)
  creditBalance            Decimal            @default(19.00) @db.Decimal(10, 2)
  trialEndsAt              DateTime?
  planStartedAt            DateTime           @default(now())
  nextBillingDate          DateTime?
  lowBalanceNotifiedAt     DateTime? // Last time low balance notification was sent
  subscriptionStatus       SubscriptionStatus @default(ACTIVE)
  pausedAt                 DateTime? // When subscription was paused
  pauseRequestedAt         DateTime? // When user requested pause (effective next month)
  pendingPlanType          PlanType? // Plan to switch to on next billing
  pendingPlanEffectiveDate DateTime? // When pending plan becomes active
  lastPaymentFailedAt      DateTime? // Last payment failure timestamp
  paymentFailureCount      Int                @default(0) // Consecutive failed payments

  users                  UserWorkspace[]
  invitations            WorkspaceInvitation[]
  agentConfigs           AgentConfig[]
  agentConversationLogs  AgentConversationLog[]
  conversationMessages   ConversationMessage[]
  whatsappWebhookEvents  WhatsappWebhookEvent[]
  carts                  Carts[]
  categories             Categories[]
  chatSessions           ChatSession[]
  customers              Customers[]
  documents              Documents[]
  faqs                   FAQ[]
  gdprContent            GdprContent[]
  languages              Languages[]
  offers                 Offers[]
  orders                 Orders[]
  products               Products[]
  sales                  Sales[]
  secureTokens           SecureToken[]
  services               Services[]
  billings               Billing[]
  shortUrls              ShortUrls[]
  usage                  Usage[]
  whatsappSettings       WhatsappSettings?
  adminSessions          AdminSession[]
  campaigns              Campaign[]
  productSearches        ProductSearch[]
  searchConversations    SearchConversations[]
  certifications         Certification[]
  types                  Type[]
  whatsappQueue          WhatsAppQueue[]
  billingTransactions    BillingTransaction[]
  softDeleteAuditLogs    SoftDeleteAuditLog[]
  callingFunctions       WorkspaceCallingFunction[] // ✅ Inverse relation
  supportTickets         SupportTicket[] // 🎫 Support tickets for this workspace
  pushCampaigns          PushCampaign[]
  pushCampaignRecipients PushCampaignRecipient[]
  customerFeedbacks      CustomerFeedback[] // 👍👎 Customer feedback

  @@index([ownerId])
  @@index([planType])
  @@index([deletedAt])
}

model Categories {
  id                String            @id @default(uuid())
  name              String
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  isActive          Boolean           @default(true)
  workspaceId       String
  slug              String
  workspace         Workspace         @relation(fields: [workspaceId], references: [id])
  offers            Offers[]          @relation("OfferCategory")
  products          Products[] // DEPRECATED: Use productCategories relation instead
  offerCategories   Offers[]          @relation("OfferCategories")
  productCategories ProductCategory[]

  @@unique([slug, workspaceId])
  @@map("categories")
}

model Sales {
  id          String      @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isActive    Boolean     @default(true)
  workspaceId String
  customers   Customers[]
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])

  @@map("sales")
}

model Languages {
  id          String    @id @default(uuid())
  name        String
  code        String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@map("languages")
}

model Products {
  id                    String                 @id @default(uuid())
  name                  String
  sku                   String?
  description           String?
  formato               String?
  price                 Float
  stock                 Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  isActive              Boolean                @default(true)
  workspaceId           String
  categoryId            String? // DEPRECATED: Use productCategories relation instead
  slug                  String                 @unique
  link                  String?                @db.VarChar(120) // Optional product external link (max 120 chars)
  status                ProductStatus          @default(ACTIVE)
  imageUrl              String[]               @default([])
  imageKey              String? // 💾 Storage key for cleanup (e.g., "products/workspace-id/product-id.jpg")
  type                  String                 @default("Temperatura ambiente")
  region                String?
  allergens             String[]               @default([])
  certifications        String[]               @default([]) // DEPRECATED: Use ProductCertification relation instead
  cartItems             CartItems[]
  orderItems            OrderItems[]
  productCertifications ProductCertification[]
  productTypes          ProductType[]
  productCategories     ProductCategory[]
  characteristics       ProductCharacteristic[]
  category              Categories?            @relation(fields: [categoryId], references: [id]) // DEPRECATED
  workspace             Workspace              @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([allergens])
  @@index([certifications])
  @@index([imageKey])
  @@map("products")
}

model Certification {
  id                    String                 @id @default(uuid())
  name                  String
  workspaceId           String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productCertifications ProductCertification[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("Certification")
}

model ProductCertification {
  productId       String
  certificationId String
  createdAt       DateTime      @default(now())
  product         Products      @relation(fields: [productId], references: [id], onDelete: Cascade)
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@id([productId, certificationId])
  @@index([certificationId])
  @@map("ProductCertification")
}

model Type {
  id           String        @id @default(uuid())
  name         String
  workspaceId  String
  price        Decimal       @default(0) @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productTypes ProductType[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([name])
  @@index([isActive])
  @@map("Type")
}

model ProductType {
  productId String
  typeId    String
  product   Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([productId, typeId])
  @@index([productId])
  @@index([typeId])
  @@map("ProductType")
}

model ProductCategory {
  productId  String
  categoryId String
  createdAt  DateTime   @default(now())
  product    Products   @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@map("ProductCategory")
}

model ProductCharacteristic {
  id        String   @id @default(uuid())
  productId String
  name      String   // Characteristic name (e.g., "superficie", "colore", "taglia")
  value     String   // Characteristic value (e.g., "42mq", "rosso", "L")
  createdAt DateTime @default(now())
  product   Products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name])
  @@map("ProductCharacteristic")
}

model WhatsAppQueue {
  id                    String    @id @default(uuid())
  workspaceId           String
  customerId            String
  phoneNumber           String
  messageContent        String    @db.Text
  status                String    @default("pending") // pending, sent, error, delivered, failed
  errorMessage          String?   @db.Text
  createdAt             DateTime  @default(now())
  deliveredAt           DateTime?
  conversationMessageId String? // FK to ConversationMessage for timeline tracking

  // 🆕 Widget Support
  channel         String    @default("whatsapp") // "whatsapp" | "widget"
  visitorId       String? // For anonymous widget users (e.g., "visitor_1726262000000_a7k2m9x1")
  isAnonymous     Boolean   @default(false) // true for widget visitors without phone
  expiresAt       DateTime? // Session expiry for anonymous widget sessions (24 hours)
  responsePayload Json? // Response from LLM (cached for polling)
  pollingAttempts Int       @default(0) // Track polling attempts
  lastPolledAt    DateTime? // Last time response was checked

  // 🧪 Playground Mode
  isPlayground Boolean @default(false) // true for test messages (skip billing & real sending)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer            Customers            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversationMessage ConversationMessage? @relation(fields: [conversationMessageId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, channel])
  @@index([customerId])
  @@index([visitorId])
  @@index([createdAt])
  @@index([conversationMessageId])
  @@index([expiresAt]) // For cleanup job
  @@map("whatsapp_queue")
}

// 🔐 WhatsApp inbound webhook de-duplication (prevents Meta retry duplicates)
model WhatsappWebhookEvent {
  id                String   @id @default(cuid())
  workspaceId       String
  externalMessageId String
  channel           String   @default("whatsapp") // "whatsapp" | "widget" (future)
  receivedAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channel, externalMessageId])
  @@index([workspaceId])
  @@index([receivedAt])
  @@map("whatsapp_webhook_events")
}

model Customers {
  id                            String                  @id @default(uuid())
  name                          String
  email                         String
  phone                         String?
  customId                      String?                 @unique // 🆕 Widget: visitor tracking ID (e.g., "webvisitor-abc123")
  address                       String?
  company                       String?
  discount                      Float?                  @default(0)
  language                      String?                 @default("it") // 🌍 Default to Italian (base language) - detects from phone prefix
  currency                      String?                 @default("USD")
  notes                         String?
  serviceIds                    String[]                @default([])
  isBlacklisted                 Boolean                 @default(false)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  deletedAt                     DateTime?
  isActive                      Boolean                 @default(false) // 🔒 Feature 174: Rule #4 - New customers are NOT registered by default
  registrationStatus            RegistrationStatus      @default(NEW) // 🆕 Customer registration state: NEW (never registered), PENDING_APPROVAL (registered, awaiting admin), ACTIVE (approved)
  workspaceId                   String
  last_privacy_version_accepted String?
  privacy_accepted_at           DateTime?
  push_notifications_consent    Boolean                 @default(false)
  push_notifications_consent_at DateTime?
  activeChatbot                 Boolean                 @default(true)
  invoiceAddress                Json?
  salesId                       String?
  cart                          Carts?
  chatSessions                  ChatSession[]
  sales                         Sales?                  @relation(fields: [salesId], references: [id])
  workspace                     Workspace               @relation(fields: [workspaceId], references: [id])
  orders                        Orders[]
  usage                         Usage[]
  billings                      Billing[]
  agentConversationLogs         AgentConversationLog[]
  conversationMessages          ConversationMessage[]
  campaignSends                 CampaignSent[]
  feedbacks                     CustomerFeedback[]
  productSearches               ProductSearch[]
  whatsappQueue                 WhatsAppQueue[]
  pushCampaignRecipients        PushCampaignRecipient[] // Campaign recipients for this customer

  @@index([phone])
  @@index([deletedAt])
  @@index([workspaceId, deletedAt])
  @@map("customers")
}

model SearchConversations {
  id           String                  @id @default(uuid())
  sessionId    String                  @unique // WhatsApp session ID or chat session ID
  workspaceId  String
  customerId   String
  state        SearchConversationState @default(ACTIVE)
  activeAgent  AgentType? // Current agent in control (null = Router decides)
  lastQuery    String? // Last search query from customer
  lastResponse String? // Last response summary
  metadata     Json? // Additional context (filters, results count, etc.)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  expiresAt    DateTime // Auto-expire after 10 minutes of inactivity

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([sessionId])
  @@index([customerId])
  @@index([expiresAt])
  @@map("search_conversations")
}

model Orders {
  id              String         @id @default(uuid())
  orderCode       String         @unique
  status          OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus? @default(PENDING)
  totalAmount     Float
  shippingAmount  Float?         @default(0)
  taxAmount       Float?         @default(0)
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  discountCode    String?
  discountAmount  Float?         @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  billedAt        DateTime? // 🔴 BILLING: Timestamp when NEW_ORDER billing (€1.00) was applied - prevents double-billing
  customerId      String
  workspaceId     String
  trackingNumber  String?

  // 🧯 INVOICE FIELDS
  invoiceUrl  String? // Public or signed URL to invoice PDF
  invoiceKey  String? // Storage key for deletion (e.g., "invoices/workspace-id/ORD-2024-001.pdf")
  invoiceDate DateTime? // When invoice was generated

  items          OrderItems[]
  creditNotes    CreditNote[]
  customer       Customers       @relation(fields: [customerId], references: [id])
  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  paymentDetails PaymentDetails?

  @@index([customerId])
  @@index([deletedAt])
  @@index([workspaceId, deletedAt])
  @@index([invoiceKey])
  @@map("orders")
}

// Nota di Credito - Partial refund linked to delivered orders
model CreditNote {
  id             String   @id @default(uuid())
  creditNoteCode String   @unique // Format: NC-{orderCode} e.g., NC-ORD-2025-001
  orderId        String
  order          Orders   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount         Float // Importo della nota di credito (positivo)
  reason         String   @db.Text // Motivo della nota di credito
  createdAt      DateTime @default(now())
  createdById    String? // User ID who created the credit note

  @@index([orderId])
  @@map("credit_notes")
}

model OrderItems {
  id             String    @id @default(uuid())
  itemType       ItemType  @default(PRODUCT)
  quantity       Int       @default(1)
  unitPrice      Float
  totalPrice     Float
  productVariant Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  orderId        String
  productId      String?
  serviceId      String?
  order          Orders    @relation(fields: [orderId], references: [id])
  product        Products? @relation(fields: [productId], references: [id])
  service        Services? @relation(fields: [serviceId], references: [id])

  @@index([deletedAt])
  @@map("order_items")
}

model Carts {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  customerId  String      @unique
  workspaceId String
  items       CartItems[]
  customer    Customers   @relation(fields: [customerId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])

  @@map("carts")
}

model CartItems {
  id        String    @id @default(uuid())
  itemType  ItemType  @default(PRODUCT)
  quantity  Int
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cartId    String
  productId String?
  serviceId String?
  cart      Carts     @relation(fields: [cartId], references: [id])
  product   Products? @relation(fields: [productId], references: [id])
  service   Services? @relation(fields: [serviceId], references: [id])

  @@map("cart_items")
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String? // SECURITY: Nullable for social-only users (Google/Facebook/Apple)
  firstName          String?
  lastName           String?
  status             UserStatus @default(ACTIVE)
  lastLogin          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?
  role               UserRole   @default(MEMBER)
  isPlatformAdmin    Boolean    @default(false) // Platform-level admin (can access backoffice)
  isDeveloperUser    Boolean    @default(false) // Developer user (skip 2FA requirement)
  twoFactorSecret    String? // TOTP secret for 2FA
  twoFactorEnabled   Boolean    @default(false) // 2FA active flag
  twoFactorEnabledAt DateTime? // When 2FA was activated
  recoveryCodes      String[]   @default([]) // 10 hashed recovery codes (bcrypt)
  authProvider       String     @default("email") // "email" | "google" | "facebook" | "apple" | "multi"
  profilePicture     String? // URL to profile picture (OAuth or NULL for default avatar)
  logo               String? // Company logo uploaded by user
  linkedProviders    Json?      @default("[]") // Array: [{provider: 'google', linkedAt: '2025-11-21T...'}]
  gdprAccepted       DateTime?
  phoneNumber        String?
  language           String     @default("ENG") // User's preferred language: ENG, ITA, ESP, POR, FRA, DEU

  // 🧾 Billing/Invoice Information (Andrea's requirement)
  companyName    String? // Nome società
  vatNumber      String? // P.IVA / VAT number
  website        String? // Sito internet
  billingPhone   String? // Telefono per fatturazione
  billingAddress String? // Indirizzo completo

  // 💳 SUBSCRIPTION & BILLING (Feature 198 - Owner-based billing)
  // Credit is SHARED across ALL owned workspaces
  planType             PlanType  @default(FREE_TRIAL)
  creditBalance        Decimal   @default(19.00) @db.Decimal(10, 2)
  trialEndsAt          DateTime?
  planStartedAt        DateTime  @default(now())
  nextBillingDate      DateTime?
  lowBalanceNotifiedAt DateTime? // Last time low balance notification was sent

  // Subscription Status
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  pausedAt           DateTime? // When subscription was paused
  pauseRequestedAt   DateTime? // When user requested pause (effective next month)

  // Pending Plan Change (for downgrades - effective next billing cycle)
  pendingPlanType          PlanType? // Plan to switch to on next billing
  pendingPlanEffectiveDate DateTime? // When pending plan becomes active

  // Payment tracking
  lastPaymentFailedAt DateTime? // Last payment failure timestamp
  paymentFailureCount Int       @default(0) // Consecutive failed payments

  // PayPal configuration (owner-level)
  paypalStatus                PayPalStatus @default(DISCONNECTED)
  isPaymentConnected          Boolean      @default(false)
  paypalClientId              String?
  paypalMerchantId            String?
  paypalEmail                 String?
  paypalEnvironment           String? // "sandbox" | "live"
  paypalConnectedAt           DateTime?
  paypalAccessTokenEncrypted  String?
  paypalRefreshTokenEncrypted String?
  paypalTokenExpiresAt        DateTime?
  paypalTokenScope            String?

  // 💳 PayPal Subscriptions (Feature: Monthly Billing)
  paypalSubscriptionId         String? // I-XXXXX - Subscription ID from PayPal
  paypalPlanId                 String? // P-XXXXX - Plan ID used for subscription
  paypalSubscriptionStatus     String? // APPROVAL_PENDING | ACTIVE | SUSPENDED | CANCELLED
  paypalNextBillingTime        DateTime? // Next automatic billing date
  paypalLastPaymentTime        DateTime? // Last successful payment timestamp
  paypalFailedPaymentsCount    Int       @default(0) // Consecutive failed payments counter
  paypalCyclesCompleted        Int       @default(0) // Number of billing cycles completed
  paypalOutstandingBalance     Decimal   @default(0) @db.Decimal(10, 2) // Outstanding balance to be charged
  paypalSubscriptionApprovedAt DateTime? // When user approved the subscription

  workspaces              UserWorkspace[]
  ownedWorkspaces         Workspace[]             @relation("OwnedWorkspaces") // Workspaces where user is owner/SUPER_ADMIN
  invitationsSent         WorkspaceInvitation[]   @relation("InvitedBy") // Invitations sent by this user
  passwordResets          PasswordReset[]
  adminSessions           AdminSession[]
  authAttempts            AuthenticationAttempt[] // Security audit trail
  twoFactorResets         TwoFactorResetToken[] // 2FA reset tokens (admin-initiated)
  adminInitiatedResets    TwoFactorResetToken[]   @relation("AdminInitiatedResets") // Resets initiated by this admin
  billingTransactions     BillingTransaction[] // Owner's billing transaction history
  monthlyInvoices         MonthlyInvoice[] // Feature 197: Monthly invoices for this owner
  invoiceCreditNotes      InvoiceCreditNote[] // Credit notes for monthly invoices
  paypalTransactions      PayPalTransaction[]
  paypalAdminTransactions PayPalTransaction[]     @relation("PayPalAdmin")
  invoiceAdjustments      InvoiceAdjustment[]
  supportTickets          SupportTicket[] // 🎫 Support tickets created by this user
  pushCampaignsCreated    PushCampaign[] // Campaigns created by this user

  @@index([deletedAt])
  @@index([planType])
  @@index([subscriptionStatus])
  @@map("users")
}

// 🔐 TwoFactorResetToken: Admin-initiated 2FA reset tokens
// Created when admin clicks "Reset 2FA" for a user who lost their phone
// User must verify password before completing 2FA re-setup
model TwoFactorResetToken {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token            String    @unique @db.VarChar(36) // UUID v4 (36 chars with hyphens)
  expiresAt        DateTime // 1 hour from creation
  usedAt           DateTime? // NULL until token is used
  createdAt        DateTime  @default(now())
  createdByAdminId String // Admin who initiated the reset
  createdByAdmin   User      @relation("AdminInitiatedResets", fields: [createdByAdminId], references: [id])

  // Security: Track password verification attempts
  passwordAttempts Int       @default(0) // Failed password attempts (max 5)
  lockedUntil      DateTime? // Lockout timestamp if too many failed attempts

  @@index([token]) // Fast token lookup
  @@index([userId, createdAt]) // Find recent tokens for a user
  @@index([expiresAt]) // Cleanup expired tokens
  @@map("two_factor_reset_tokens")
}

model AuthenticationAttempt {
  id            String   @id @default(cuid())
  userId        String? // NULL if user doesn't exist (failed registration/login)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         String // Email attempted (track even if user doesn't exist)
  attemptType   String // "registration" | "login" | "2fa" | "password_reset" | "oauth-google" | "oauth-facebook" | "oauth-apple"
  success       Boolean
  failureReason String? // Error message if failed
  ipAddress     String?  @db.VarChar(45) // IPv4 or IPv6 for rate limiting
  userAgent     String?  @db.Text // Browser fingerprinting
  metadata      Json? // Additional context (OAuth response, etc.)
  timestamp     DateTime @default(now())

  @@index([email, timestamp]) // Rate limit by email
  @@index([ipAddress, timestamp]) // Rate limit by IP
  @@index([attemptType, success]) // Fast failed attempt queries
  @@index([timestamp]) // Cleanup old logs
  @@map("authentication_attempts")
}

