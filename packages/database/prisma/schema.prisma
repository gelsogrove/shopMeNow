model RegistrationAttempts {
  id            String   @id @default(cuid())
  phoneNumber   String
  workspaceId   String
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime @default(now())
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())
