model ChatSession {
  id          String    @id @default(uuid())
  status      String    @default("active")
  context     Json?     @default("{}")
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  workspaceId String
  customerId  String
  customer    Customers @relation(fields: [customerId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  messages    Message[]

  // 🆕 Widget Support
  isAnonymous Boolean   @default(false) // true for widget visitors without phone
  visitorId   String? // For anonymous widget users (same format as WhatsAppQueue)
  expiresAt   DateTime? // Session expiry for anonymous visitors (24 hours)
  channel     String    @default("whatsapp") // "whatsapp" | "widget"

  // 🔒 CONCURRENCY SAFETY: Unique constraint prevents duplicate active sessions
  // Only ONE active session allowed per customer at any time
  @@unique([customerId, status], name: "unique_active_session")
  @@index([customerId, status], name: "idx_customer_status")
  @@index([workspaceId], name: "idx_workspace")
  @@index([workspaceId, customerId], name: "idx_workspace_customer") // Common lookup
  @@index([createdAt], name: "idx_chat_session_created") // For time-based queries
  @@index([workspaceId, createdAt], name: "idx_workspace_created") // Dashboard stats
  @@index([deletedAt])
  @@index([workspaceId, deletedAt])
  @@index([visitorId]) // For widget lookups
  @@index([channel])
  @@index([expiresAt]) // For cleanup job
  @@map("chat_sessions")
}

model Message {
  id                 String           @id @default(uuid())
  direction          MessageDirection
  content            String
  type               MessageType      @default(TEXT)
  status             String           @default("sent")
  aiGenerated        Boolean          @default(false)
  metadata           Json?            @default("{}")
  read               Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  chatSessionId      String
  functionCallsDebug String?
  processingSource   String?
  translatedQuery    String?
  processedPrompt    String?
  debugInfo          String? // 🔧 NEW: Debug information as JSON string

  // 🆕 WHATSAPP INTEGRATION FIELDS
  whatsappStatus    String? // "sent" | "failed" | "pending" | "delivered" | "read"
  whatsappError     String? // Error message if failed
  whatsappMessageId String? // WhatsApp message ID for tracking
  sentBy            String? // userId of operator who sent (if manual)

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id])

  // 🚀 PERFORMANCE INDEXES
  @@index([chatSessionId])
  @@index([whatsappStatus])
  @@index([whatsappMessageId])
  @@index([sentBy])
  @@index([createdAt], name: "idx_message_created") // Rate limiting queries
  @@index([direction, createdAt], name: "idx_direction_created") // Rate limiting by direction
  @@index([chatSessionId, createdAt], name: "idx_msg_session_created") // Chat history pagination
  @@index([chatSessionId, direction], name: "idx_session_direction") // Filter by direction
  @@index([deletedAt])
  @@map("messages")
}

// 📦 ARCHIVED MESSAGES - Old messages moved here for performance
// Messages older than 6 months are archived by scheduler job
// ALL fields match Message table for easy restore if needed
model MessageArchive {
  id            String           @id @default(uuid())
  originalId    String // Original message ID before archiving
  direction     MessageDirection
  content       String
  type          MessageType      @default(TEXT)
  status        String           @default("sent")
  aiGenerated   Boolean          @default(false)
  metadata      Json?            @default("{}")
  read          Boolean          @default(false)
  createdAt     DateTime // Original creation date
  updatedAt     DateTime // Original update date
  archivedAt    DateTime         @default(now()) // When it was archived
  chatSessionId String
  workspaceId   String // Denormalized for easy cleanup
  customerId    String // Denormalized for easy lookup

  // Debug/processing fields (for full restore)
  functionCallsDebug String?
  processingSource   String?
  translatedQuery    String?
  processedPrompt    String?
  debugInfo          String?

  // WhatsApp fields
  whatsappStatus    String?
  whatsappError     String?
  whatsappMessageId String?
  sentBy            String?

  @@index([workspaceId])
  @@index([customerId])
  @@index([chatSessionId])
  @@index([createdAt])
  @@index([archivedAt])
  @@index([originalId]) // For restore lookups
  @@map("messages_archive")
}

