// ============================================================
// CALENDAR & APPOINTMENT BOOKING (Feature: Google Calendar)
// ============================================================

// Appointment Types: servizi offerti (consulenza, massaggio, etc.)
// Confirmed Appointment: appuntamento confermato (fonte di verità per reminder/billing)
// Google Calendar è fonte esterna, questo è la copia locale per scheduler/billing/history
model Appointment {
  id                   String    @id @default(uuid())
  workspaceId          String
  customerId           String    // Customers.id
  serviceId            String    // Services.id (booking service type)

  // Timing (UTC)
  startTime            DateTime  // Inizio appuntamento (UTC)
  endTime              DateTime  // Fine appuntamento (UTC) = startTime + duration + bufferTime
  timezone             String    @default("Europe/Rome") // IANA timezone per display cliente

  // Google Calendar sync
  googleEventId        String?   // Google Calendar Event ID (null se non sincronizzato)
  googleEventLink      String?   // Link diretto al Google Calendar event
  googleCalendarId     String?   // Calendar ID usato (default "primary")

  // Status
  status               String    @default("confirmed") // "confirmed" | "cancelled" | "completed" | "no_show"
  cancelledAt          DateTime? // When cancelled
  cancellationReason   String?   @db.Text
  cancelledBy          String?   // "customer" | "admin" | "system"

  // Customer details (snapshot al momento prenotazione, non dipende da Customers record)
  customerName         String?
  customerPhone        String?
  customerEmail        String?
  customerNotes        String?   @db.Text
  adminNotes           String?   @db.Text

  // Channel that booked (determines reminder channel)
  bookedVia            String    @default("whatsapp") // "whatsapp" | "widget" | "admin"

  // Reminder tracking
  reminder24hSentAt    DateTime? // When 24h reminder was sent (null = not sent yet)
  reminder1hSentAt     DateTime? // When 1h reminder was sent (null = not sent yet)
  reminder30mSentAt    DateTime? // When 30min reminder was sent (null = not sent yet)
  reminderChannel      String?   // "whatsapp" | "email" — actual channel used for this appointment

  // Billing
  reminderBilledAt     DateTime? // When billing record was created for reminders
  reminderBillingTotal Decimal?  @default(0) @db.Decimal(10, 2) // Total charged for reminders

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service              Services        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customer             Customers       @relation(fields: [customerId], references: [id])

  @@index([workspaceId, status])
  @@index([workspaceId, startTime]) // Scheduler: finds upcoming appointments
  @@index([customerId, status])
  @@index([googleEventId]) // Deduplication check
  @@index([startTime]) // Scheduler global scan
  @@map("appointments")
}

// Google Calendar OAuth Connection (1 per workspace)
model GoogleCalendarConnection {
  id                   String    @id @default(uuid())
  workspaceId          String    @unique // 1:1 relation
  calendarId           String    @default("primary") // Google Calendar ID (default "primary")
  accessToken          String    @db.Text // Encrypted OAuth access token
  refreshToken         String    @db.Text // Encrypted OAuth refresh token
  tokenExpiry          DateTime  // When access token expires
  scope                String[]  @default(["https://www.googleapis.com/auth/calendar"]) // OAuth scopes granted
  connectedAt          DateTime  @default(now())
  lastSyncAt           DateTime? // Last successful cache sync
  isActive             Boolean   @default(true)
  errorMessage         String?   @db.Text // Last error (token revoked, quota exceeded)

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("google_calendar_connections")
}

// Business Hours: orari di lavoro settimanali
model WorkspaceBusinessHours {
  id                   String    @id @default(uuid())
  workspaceId          String
  dayOfWeek            Int       // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime            String    // "09:00" (HH:mm format)
  endTime              String    // "17:00" (HH:mm format)
  isActive             Boolean   @default(true)

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dayOfWeek]) // 1 orario per giorno (espandibile con multi-shift in futuro)
  @@index([workspaceId, isActive])
  @@map("workspace_business_hours")
}

// Blackout Periods: chiusure straordinarie (vacanze, manutenzione)
model BlackoutPeriod {
  id                   String    @id @default(uuid())
  workspaceId          String
  startDate            DateTime  // Inizio chiusura (UTC)
  endDate              DateTime  // Fine chiusura (UTC)
  reason               String?   @db.Text // "Vacanze estive 2024", "Manutenzione sistema"
  createdAt            DateTime  @default(now())

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startDate, endDate])
  @@map("blackout_periods")
}

// Pending Appointments: fallback quando Google Calendar offline
model PendingAppointment {
  id                   String             @id @default(uuid())
  workspaceId          String
  customerId           String             // Chi ha prenotato (phone number da Customers)
  serviceId            String             // Services.id (booking service type)
  requestedStartTime   DateTime           // Slot richiesto (UTC)
  requestedEndTime     DateTime           // Slot fine (UTC)
  customerNotes        String?            @db.Text
  adminNotes           String?            @db.Text // Note interne admin
  status               String             @default("pending") // "pending" | "synced" | "rejected"
  syncedEventId        String?            // Google Calendar Event ID se sincronizzato
  syncedAt             DateTime?
  rejectedAt           DateTime?
  rejectionReason      String?            @db.Text
  createdAt            DateTime           @default(now())

  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service              Services           @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status])
  @@index([customerId])
  @@map("pending_appointments")
}

// Reminder Lock: atomicità per evitare duplicati reminder
model ReminderLock {
  id                   String    @id @default(uuid())
  workspaceId          String
  appointmentId        String    // Appointment ID
  googleEventId        String?   // Google Calendar Event ID (optional if not synced)
  reminderType         String    // "1h" | "24h"
  lockKey              String    @unique // "reminder-{type}-{appointmentId}" — dedup key
  sentAt               DateTime  @default(now())
  expiresAt            DateTime  // Cleanup automatico

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, reminderType]) // Previene duplicati
  @@index([expiresAt]) // Cleanup job
  @@map("reminder_locks")
}

// Late Cancellation Attempts: analytics tentativi cancellazione tardiva
model LateCancellationAttempt {
  id                   String             @id @default(uuid())
  workspaceId          String
  customerId           String             // Chi ha tentato cancellazione
  serviceId            String             // Services.id (booking service type)
  googleEventId        String?            // Google Calendar Event ID (optional until GCal integration)
  scheduledStartTime   DateTime           // Quando era l'appuntamento (UTC)
  attemptedAt          DateTime           @default(now())
  tooLateThreshold     Int                // Ore di preavviso richiesto (24, 48, etc.)

  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service              Services           @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, customerId])
  @@index([attemptedAt])
  @@map("late_cancellation_attempts")
}

// Appointment GDPR Log: traccia eliminazioni eventi Google Calendar
model AppointmentGdprLog {
  id                   String    @id @default(uuid())
  workspaceId          String
  customerId           String    // Who requested deletion
  googleEventId        String?   // Google Calendar Event ID deleted (optional until GCal integration)
  deletedAt            DateTime  @default(now())
  deletedBy            String    @default("customer") // "customer" | "admin" | "gdpr_batch"
  reason               String?   @db.Text // "GDPR request", "Customer cancel", etc.

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, customerId])
  @@index([deletedAt])
  @@map("appointment_gdpr_logs")
}

// ============================================================
// ONBOARDING QUESTIONNAIRE
// ============================================================
model OnboardingQuestionnaire {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  // Contact info (optional — only if user consents to be contacted)
  fullName    String?
  email       String?
  phone       String?
  company     String?

  // v2 Step answers (new questionnaire)
  stepIndustry          String?  // "real_estate" | "retail" | "food_hospitality" | "professions" | "b2b" | "education" | "other"
  stepGoal              String?  // "support" | "leads" | "sales" | "bookings" | "communications"
  stepHumanSupport      String?  // "yes_handoff" | "partial" | "full_auto"
  stepPushMarketing     String?  // "yes" | "no"
  stepReminders         String?  // "yes" | "no"
  stepWidget            String?  // "yes_widget" | "whatsapp_only" | "both"
  stepSalesAgents       String?  // "yes" | "general" | "no"
  stepEcommerce         String?  // "yes" | "no" | "planning"
  stepEcommercePlatform String?  // "wordpress" | "prestashop" | "magento" | "other"
  stepIntegrations      String?  // "yes" | "no" | "learn_more"
  stepPrivacy           String?  // "ok" | "concerns" | "need_info"
  stepOnPremise         String?  // "yes" | "interested" | "cloud"
  stepHelpful           String?  // "yes" | "maybe" | "exploring"
  stepInterest          String?  // "0" | "1" | "2" | "3" | "4" | "5" (stars rating)
  stepOther             String?  // free text
  lang                  String?  // "it" | "en" | "es" | "pt"
  wantsContact          Boolean  @default(false)

  // v1 legacy fields (kept nullable for backward compat)
  stepChannel      String?
  stepTimeSaving   String?
  stepDocuments    String?
  stepIntegration  String?
  stepHandoff      String?
  stepMarketing    String?

  // Admin management
  status      String   @default("NEW")  // "NEW" | "VIEWED"
  adminNotes  String?

  @@map("onboarding_questionnaires")
}
