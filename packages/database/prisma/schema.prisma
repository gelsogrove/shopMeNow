// Support Ticket Enums
enum SupportIssueType {
  ACCOUNT_ISSUE
  PLAN_AND_BILLING
  WHATSAPP
  WIDGET
  SALES_AGENT
  SUPPORT
  OTHER
}

enum SupportTicketStatus {
