// Conversation Messages - Complete history for LLM Router context
model ConversationMessage {
  id                String          @id @default(cuid())
  workspaceId       String
  customerId        String
  conversationId    String
  role              String // "user", "assistant", "function", "system"
  content           String          @db.Text
  agentType         String? // "ROUTER", "PRODUCT_SEARCH", etc.
  functionName      String? // If role="function", name of function called
  functionArguments Json? // If role="function", arguments passed
  tokensUsed        Int?
  debugInfo         String? // ✅ Debug information as JSON string (for message flow tracking)
  deliveredAt       DateTime? // ✅ WhatsApp delivery timestamp (when message sent via queue)
  deliveryStatus    String          @default("not_queued") // "not_queued" (never sent), "pending" (in queue), "sent" (delivered), "error" (failed)
  createdAt         DateTime        @default(now())
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customers       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsAppQueue     WhatsAppQueue[] // Inverse relation for queue tracking

  @@index([conversationId, createdAt])
  @@index([workspaceId, customerId])
  @@index([createdAt])
  @@map("conversation_messages")
}

// SUBSCRIPTION & BILLING SYSTEM

enum PlanType {
  FREE_TRIAL // 14 days trial with €29 credit
  BASIC // €29/month - 1 channel, 50 products, 50 customers
  PREMIUM // €49/month - 2 channels, 100 products, 100 customers
  ENTERPRISE // Custom pricing - unlimited everything
}

// Feature 197: Subscription status for billing separation
enum SubscriptionStatus {
  ACTIVE // Normal operation - chatbot responds
  PAUSE_PENDING // User requested pause - effective next month
  PAUSED // Subscription paused - no billing, no chatbot
  PAYMENT_FAILED // Payment failed - chatbot blocked until payment
  CANCELLED // Admin/user cancelled - no billing, access blocked
}

enum TransactionType {
  MESSAGE // -€0.10 per WhatsApp message
  NEW_ORDER // -€1.00 per order created
  PUSH_NOTIFICATION // -€1.00 per push notification
  APPOINTMENT_REMINDER // -€0.50 per WhatsApp appointment reminder
  RECHARGE // +€X credit recharge
  MONTHLY_FEE // -€29/€59 monthly subscription fee
  UPGRADE_FEE // Pro-rata fee when upgrading plan
  ADJUSTMENT // Manual adjustment by admin
  INITIAL_CREDIT // +€29 initial trial credit
  BONUS // +€X gift credit (not invoiced)
  INVOICE_PAID // Bank charge for monthly invoice (plan + usage) - does NOT affect credit
}

// Transaction history for billing - tracks all credit movements
// Feature 198: userId is primary key for billing (owner-based)
// workspaceId is optional for operation tracking (which channel was used)
model BillingTransaction {
  id            String          @id @default(cuid())
  userId        String // Owner who owns the credit
  workspaceId   String? // Optional: which workspace/channel originated the charge
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2) // Negative for charges, positive for credits
  balanceAfter  Decimal         @db.Decimal(10, 2) // Balance after this transaction
  description   String
  referenceId   String? // Order ID, message ID, etc.
  referenceType String? // "order", "message", "push", etc.
  metadata      Json? // Additional context
  createdAt     DateTime        @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([type])
  @@index([createdAt])
  @@map("billing_transactions")
}

model PayPalTransaction {
  id          String                  @id @default(cuid())
  userId      String
  invoiceId   String?
  amount      Decimal                 @db.Decimal(10, 2)
  currency    String                  @default("EUR")
  status      PayPalTransactionStatus
  notes       String?
  createdAt   DateTime                @default(now())
  adminUserId String?

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice   MonthlyInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  adminUser User?           @relation("PayPalAdmin", fields: [adminUserId], references: [id])

  @@index([userId])
  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
  @@map("paypal_transactions")
}

// Feature 197: Monthly Invoice for billing tracking
// Tracks subscription fees + credit usage per month per owner
enum InvoiceStatus {
  DRAFT // Current month, still accumulating charges
  PENDING // Month ended, awaiting payment
  PAID // Successfully charged
  FAILED // Payment failed (can retry)
  CANCELLED // Admin removed from fails list - user won't pay
}

enum PayPalStatus {
  DISCONNECTED
  CONNECTED
}

enum PayPalTransactionStatus {
  SUCCESS
  FAILED
}

model MonthlyInvoice {
  id            String  @id @default(cuid())
  userId        String // Owner of the invoice (Feature 198)
  invoiceNumber String? @unique // Human-readable invoice number (e.g. INV-2026-01-0001)

  // Period
  periodStart DateTime // 1st of month 00:00:00
  periodEnd   DateTime // Last day of month 23:59:59
  periodMonth Int // Month (1-12)
  periodYear  Int // Year (e.g., 2025)

  // Amounts
  subscriptionAmount Decimal @db.Decimal(10, 2) // €19/€49/€99 monthly fee
  creditUsage        Decimal @db.Decimal(10, 2) // Total consumption from wallet
  creditDebt         Decimal @default(0) @db.Decimal(10, 2) // Negative balance carried over
  creditNotesTotal   Decimal @default(0) @db.Decimal(10, 2)
  subtotalAmount     Decimal @default(0) @db.Decimal(10, 2)
  taxRate            Decimal @default(0.22) @db.Decimal(5, 4)
  taxAmount          Decimal @default(0) @db.Decimal(10, 2)
  totalAmount        Decimal @db.Decimal(10, 2) // Total to charge

  // Status
  status              InvoiceStatus @default(DRAFT)
  paidAt              DateTime?
  paypalTransactionId String?
  paymentRetryCount   Int           @default(0) // Track payment retry attempts
  adminNotes          String?
  adminMarkedById     String?
  adminMarkedAt       DateTime?

  // Metadata
  planType       PlanType // Plan during this period
  itemsBreakdown Json // { messages: 150, orders: 10, pushes: 5, ... }

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditNotes        InvoiceCreditNote[]
  adjustments        InvoiceAdjustment[]
  paypalTransactions PayPalTransaction[]

  @@unique([userId, periodYear, periodMonth])
  @@index([userId])
  @@index([status])
  @@index([periodYear, periodMonth])
  @@map("monthly_invoices")
}

model InvoiceAdjustment {
  id             String   @id @default(cuid())
  invoiceId      String
  userId         String
  amount         Decimal  @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?

  invoice MonthlyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([userId])
  @@map("invoice_adjustments")
}

model InvoiceCreditNote {
  id             String   @id @default(cuid())
  invoiceId      String
  userId         String
  amount         Decimal  @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?

  invoice MonthlyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([userId])
  @@map("invoice_credit_notes")
}

// Plan configuration - dynamic limits from database
model PlanConfiguration {
  id                  String   @id @default(cuid())
  planType            PlanType @unique
  displayName         String // "Free Trial", "Basic", "Premium", "Enterprise"
  monthlyFee          Decimal  @db.Decimal(10, 2)
  maxChannels         Int
  maxProducts         Int
  maxCustomers        Int
  maxTeamMembers      Int?     @map("max_team_members") // NULL = unlimited (for PREMIUM/ENTERPRISE)
  messageCost         Decimal  @db.Decimal(10, 2) // €0.10
  orderCost           Decimal  @db.Decimal(10, 2) // €1.00
  pushCost            Decimal  @db.Decimal(10, 2) // €1.00
  reminderCost        Decimal  @default(0.50) @db.Decimal(10, 2) // €0.50 - WhatsApp appointment reminder
  lowBalanceThreshold Decimal  @db.Decimal(10, 2) // €5.00
  trialDays           Int      @default(0) // 14 for FREE_TRIAL, 0 for others
  initialCredit       Decimal  @default(0) @db.Decimal(10, 2) // €19 for FREE_TRIAL
  features            Json? // Additional features list
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([planType])
  @@index([isActive])
  @@map("plan_configurations")
}

enum BillingType {
  MONTHLY_CHANNEL // €19.00 - Monthly subscription cost (LEGACY)
  MESSAGE // €0.15 - Per message/interaction cost (LLM responses) (LEGACY)
  NEW_CUSTOMER // €1.50 - New customer registration (LEGACY)
  NEW_ORDER // €1.50 - New order placed (LEGACY)
  PUSH_CAMPAIGN // €1.00 - Push notification (advertising campaigns) (LEGACY)
  FEEDBACK // No cost - Customer feedback
  ORDER_REVIEW // No cost - Order review
  CAMPAIGN_LINK // No cost - Campaign link click
  // NOTE: Legacy billing - use BillingTransaction for new billing system
}

enum CampaignFrequency {
  ONCE
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum CampaignTargetType {
  ALL
  MANUAL
  TAGS
  SELECTED
}

enum PushCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum PushCampaignBillingStatus {
  PENDING
  PARTIAL
  BILLED
  FAILED
}

enum PushCampaignChannel {
  WHATSAPP
}

enum PushCampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// 🚀 Push Campaigns v2 (promotional/scheduled sends)
model PushCampaign {
  id                 String                    @id @default(cuid())
  workspaceId        String
  createdByUserId    String?
  name               String // Title of the campaign
  status             PushCampaignStatus        @default(DRAFT)
  channel            PushCampaignChannel       @default(WHATSAPP)
  frequency          CampaignFrequency         @default(ONCE)
  isActive           Boolean                   @default(true)
  targetingType      CampaignTargetType        @default(ALL)
  targetCustomerIds  String[]                  @default([]) // For MANUAL targeting
  tagId              String? // For TAGS targeting
  message            String?                   @db.Text // The push message content
  sendAt             DateTime? // First run/scheduled time
  nextRunAt          DateTime? // Calculated next run
  lastRunAt          DateTime? // Last execution time
  templateId         String?
  templateLocale     String?
  bodyPreview        String?                   @db.Text
  targetTags         String[]                  @default([]) // Deprecated in favor of tagId or targetCustomerIds
  mediaUrl           String?
  expectedRecipients Int                       @default(0)
  actualSent         Int                       @default(0)
  actualFailed       Int                       @default(0)
  actualSkipped      Int                       @default(0)
  costPerMessage     Decimal                   @default(1.00) @db.Decimal(10, 2)
  billingStatus      PushCampaignBillingStatus @default(PENDING)
  throttlePerSecond  Int                       @default(10)
  batchSize          Int                       @default(50)
  lastError          String?                   @db.Text
  metadata           Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  workspace  Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User?                   @relation(fields: [createdByUserId], references: [id])
  recipients PushCampaignRecipient[]
  whatsappQueue WhatsAppQueue[]

  @@index([workspaceId])
  @@index([status])
  @@index([sendAt])
  @@index([nextRunAt])
  @@map("push_campaigns")
}

model PushCampaignRecipient {
  id            String                      @id @default(cuid())
  campaignId    String
  workspaceId   String
  customerId    String?
  phone         String
  status        PushCampaignRecipientStatus @default(PENDING)
  errorCode     String?
  errorMessage  String?                     @db.Text
  sentAt        DateTime?
  messageId     String?
  priceCharged  Decimal                     @default(0) @db.Decimal(10, 2)
  isBlacklisted Boolean                     @default(false)
  isBlocked     Boolean                     @default(false)
  isFake        Boolean                     @default(false)
  optOutAt      DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  campaign  PushCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  whatsappQueue WhatsAppQueue[]
  customer  Customers?   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([workspaceId])
  @@index([status])
