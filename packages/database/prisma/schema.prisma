// 🆕 Customer Registration Status
// Tracks the customer's registration journey:
// - NEW: First contact, never completed registration form
// - PENDING_APPROVAL: Completed registration, waiting for admin approval
// - ACTIVE: Approved by admin, full access to features
enum RegistrationStatus {
  NEW              // Default: customer has never registered
  PENDING_APPROVAL // Customer completed registration form, awaiting admin approval
  ACTIVE           // Admin approved, customer has full access
}

