// Status of a workspace invitation
enum InvitationStatus {
  PENDING // Waiting for user to accept
  ACCEPTED // User accepted the invitation
  CANCELLED // SUPER_ADMIN cancelled the invitation
  EXPIRED // Token expired (>7 days)
}

