// Status of a workspace invitation
enum InvitationStatus {
  PENDING   // Waiting for user to accept
  ACCEPTED  // User accepted the invitation
  CANCELLED // SUPER_ADMIN cancelled the invitation
  EXPIRED   // Token expired (>7 days)
}

// Workspace invitation for team management
model WorkspaceInvitation {
  id          String           @id @default(cuid())
  email       String           // Email of the invited user (lowercase normalized)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenHash   String           @unique // SHA-256 hash of the invitation token
  invitedById String
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id])
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime         // Token expiry (7 days from creation)
  createdAt   DateTime         @default(now())
  acceptedAt  DateTime?        // When the invitation was accepted

  @@index([workspaceId])
  @@index([email])
  @@index([status])
  @@index([tokenHash])
  @@map("workspace_invitations")
}

model ShortUrls {
  id             String    @id @default(cuid())
  shortCode      String    @unique @db.VarChar(10)
  originalUrl    String    @db.Text
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clicks         Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shortCode])
  @@index([workspaceId])
  @@index([expiresAt])
}

enum BusinessType {
  ECOMMERCE
  RESTAURANT
  CLINIC
  RETAIL
  SERVICES
  GENERIC
}

enum ItemType {
  PRODUCT
  SERVICE
}

model Billing {
  id            String      @id @default(cuid())
  workspaceId   String
  customerId    String?
  amount        Float // Current charge amount (e.g., €0.15 or €1.50)
  type          BillingType
  description   String
  userQuery     String? // User's original question/message
  previousTotal Float       @default(0) // Total before this charge
  currentCharge Float       @default(0) // Same as amount (for clarity in formula)
  newTotal      Float       @default(0) // previousTotal + currentCharge = newTotal
  createdAt     DateTime    @default(now())
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  customer      Customers?  @relation(fields: [customerId], references: [id])

  @@index([workspaceId])
  @@index([customerId])
  @@index([type])
  @@index([createdAt])
}

model AgentConversationLog {
  id              String     @id @default(cuid())
  workspaceId     String     // SECURITY: multi-tenant isolation
  customerId      String     // SECURITY: customer isolation
  conversationId  String     // Group messages: "conv_123"
  messageId       String     // Original message ID
  step            Int        // Execution order: 1, 2, 3... (Router=1, Agent=2, Safety=3)
  agentType       String     // "ROUTER", "PRODUCT_SEARCH", etc.
  agentAction     String     // "classify_intent", "search_products", "translate"
  inputMessage    String     @db.Text // Input to this agent
  agentPrompt     String?    @db.Text // Complete prompt used (optional, can be large)
  llmModel        String?    // "openai/gpt-4o-mini"
  llmResponse     String     @db.Text // Raw LLM output
  confidence      Float?     // 0.0-1.0 confidence score
  reasoning       String?    @db.Text // Agent's reasoning (if provided)
  tokensUsed      Int?       // Total tokens (input + output)
  executionTimeMs Int?       // Latency in milliseconds
  functionsCalled Json?      // Array: [{name, params, result}]
  hasError        Boolean    @default(false)
  errorMessage    String?    @db.Text
  createdAt       DateTime   @default(now())
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customers  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([workspaceId, customerId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([agentType])
  @@index([hasError])
  @@map("agent_conversation_logs")
}

// Conversation Messages - Complete history for LLM Router context
model ConversationMessage {
  id                String    @id @default(cuid())
  workspaceId       String
  customerId        String
  conversationId    String
  role              String // "user", "assistant", "function", "system"
  content           String    @db.Text
  agentType         String? // "ROUTER", "PRODUCT_SEARCH", etc.
  functionName      String? // If role="function", name of function called
  functionArguments Json? // If role="function", arguments passed
  tokensUsed        Int?
  debugInfo         String? // ✅ Debug information as JSON string (for message flow tracking)
  deliveredAt       DateTime? // ✅ WhatsApp delivery timestamp (when message sent via queue)
  deliveryStatus    String    @default("not_queued") // "not_queued" (never sent), "pending" (in queue), "sent" (delivered), "error" (failed)
  createdAt         DateTime  @default(now())
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([workspaceId, customerId])
  @@index([createdAt])
  @@map("conversation_messages")
}

// ============================================================================
// SUBSCRIPTION & BILLING SYSTEM
// ============================================================================

enum PlanType {
  FREE_TRIAL  // 14 days trial with €29 credit
  BASIC       // €29/month - 1 channel, 50 products, 50 customers
  PREMIUM     // €49/month - 2 channels, 100 products, 100 customers
  ENTERPRISE  // Custom pricing - unlimited everything
}

enum TransactionType {
  MESSAGE           // -€0.10 per WhatsApp message
  NEW_ORDER         // -€1.00 per order created
  PUSH_NOTIFICATION // -€1.00 per push notification
  RECHARGE          // +€X credit recharge
  MONTHLY_FEE       // -€29/€59 monthly subscription fee
  UPGRADE_FEE       // Pro-rata fee when upgrading plan
  ADJUSTMENT        // Manual adjustment by admin
  INITIAL_CREDIT    // +€29 initial trial credit
}

// Transaction history for billing - tracks all credit movements
model BillingTransaction {
  id            String          @id @default(cuid())
  workspaceId   String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2) // Negative for charges, positive for credits
  balanceAfter  Decimal         @db.Decimal(10, 2) // Balance after this transaction
  description   String
  referenceId   String?         // Order ID, message ID, etc.
  referenceType String?         // "order", "message", "push", etc.
  metadata      Json?           // Additional context
  createdAt     DateTime        @default(now())
  
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@index([createdAt])
  @@map("billing_transactions")
}

// Plan configuration - dynamic limits from database
model PlanConfiguration {
  id                   String    @id @default(cuid())
  planType             PlanType  @unique
  displayName          String    // "Free Trial", "Basic", "Premium", "Enterprise"
  monthlyFee           Decimal   @db.Decimal(10, 2)
  maxChannels          Int
  maxProducts          Int
  maxCustomers         Int
  messageCost          Decimal   @db.Decimal(10, 2) // €0.10
  orderCost            Decimal   @db.Decimal(10, 2) // €1.00
  pushCost             Decimal   @db.Decimal(10, 2) // €1.00
  lowBalanceThreshold  Decimal   @db.Decimal(10, 2) // €5.00
  trialDays            Int       @default(0) // 14 for FREE_TRIAL, 0 for others
  initialCredit        Decimal   @db.Decimal(10, 2) @default(0) // €29 for FREE_TRIAL
  features             Json?     // Additional features list
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([planType])
  @@index([isActive])
  @@map("plan_configurations")
}

enum BillingType {
  MONTHLY_CHANNEL // €19.00 - Monthly subscription cost (LEGACY)
  MESSAGE // €0.15 - Per message/interaction cost (LLM responses) (LEGACY)
  NEW_CUSTOMER // €1.50 - New customer registration (LEGACY)
  NEW_ORDER // €1.50 - New order placed (LEGACY)
  PUSH_CAMPAIGN // €1.00 - Push notification (advertising campaigns) (LEGACY)
  FEEDBACK // No cost - Customer feedback
  ORDER_REVIEW // No cost - Order review
  CAMPAIGN_LINK // No cost - Campaign link click
  // NOTE: Legacy billing - use BillingTransaction for new billing system
}

enum CampaignFrequency {
  ONCE // Una sola volta (no ripetizione)
  WEEKLY // Ogni 7 giorni
  BIWEEKLY // Ogni 14 giorni
  MONTHLY // Ogni 30 giorni
  BIMONTHLY // Ogni 60 giorni
  QUARTERLY // Ogni 90 giorni
  SEMIANNUAL // Ogni 180 giorni (6 mesi)
  ANNUAL // Ogni 365 giorni
}

enum CampaignTargetType {
  ALL // Tutti i customer attivi del workspace
  SELECTED // Solo customer IDs specificati
}

model Campaign {
  id             String            @id @default(cuid())
  workspaceId    String
  name           String // "Richiesta Feedback Semestrale"
  messagePreview String            @db.Text // Markdown per visualizzazione admin (con token [FEEDBACK], {{nome}}, ecc)
  frequency      CampaignFrequency
  isActive       Boolean           @default(true)

  // Destinatari
  targetType  CampaignTargetType @default(ALL)
  customerIds String[]           @default([]) // Array di customer IDs se targetType = SELECTED

  // Template WhatsApp (opzionale, per uso futuro con Meta Business API)
  templateName   String? // Nome template Meta (es: "feedback_request_v1")
  templateParams Json? // Parametri template WhatsApp come JSON

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastRunAt DateTime? // Ultima esecuzione cron

  // Relations
  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sends     CampaignSent[]
  feedbacks CustomerFeedback[]

  @@index([workspaceId])
  @@index([isActive])
  @@index([frequency])
}

model CampaignSent {
  id          String    @id @default(cuid())
  campaignId  String
  customerId  String
  workspaceId String
  sentAt      DateTime  @default(now())
  tokenUsed   String? // Token generato per tracking click
  clickedAt   DateTime? // Se customer ha cliccato sul link

  // Relations
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([customerId])
  @@index([workspaceId])
  @@index([sentAt])
}

model CustomerFeedback {
  id          String   @id @default(cuid())
  customerId  String
  workspaceId String
  campaignId  String? // Opzionale: da quale campagna arriva
  rating      Int // 1-5 stelline
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  customer Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([workspaceId])
  @@index([campaignId])
  @@index([createdAt])
}

model AdminSession {
  id             String     @id @default(cuid())
  sessionId      String     @unique @db.VarChar(64)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  expiresAt      DateTime
  lastActivityAt DateTime   @default(now())
  ipAddress      String?    @db.VarChar(45)
  userAgent      String?    @db.Text
  isActive       Boolean    @default(true)

  @@index([sessionId])
  @@index([userId])
  @@index([expiresAt])
  @@index([isActive])
  @@map("admin_sessions")
}

// ============================================================================
// PRICING CONFIGURATION - Single Source of Truth for all pricing
// ============================================================================
model PricingConfig {
  id          String      @id @default(cuid())
  type        PricingType // PLAN, USAGE, or THRESHOLD
  key         String      @unique // e.g., "BASIC_MONTHLY", "MESSAGE", "FREE_MESSAGES"
  value       Float       // The actual price or threshold value
  description String?     @db.Text // Human-readable description
  isActive    Boolean     @default(true) // Can be toggled without deleting
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([key])
  @@index([isActive])
  @@map("pricing_config")
}

enum PricingType {
  PLAN      // Monthly subscription plans (€0, €29, €59, €199)
  USAGE     // Per-action costs (€0.15/message, €1.50/customer, etc.)
  THRESHOLD // Free tier limits (200 messages, 50 products, etc.)
}

enum AgentType {
  ROUTER                // order: 0 - Intent classification + FAQ
  OPERATOR              // order: 0.5 - Human operator manual message
  PRODUCT_SEARCH        // order: 2 - Product search specialist
  CART_MANAGEMENT       // order: 3 - Cart operations
  ORDER_TRACKING        // order: 4 - Order viewing
  CUSTOMER_SUPPORT      // order: 5 - Support & escalation
  SUMMARY_AGENT         // order: 5.5 - Conversation summarization
  PROFILE_MANAGEMENT    // order: 6 - Profile modifications
  NOTIFICATIONS         // order: 7 - Push notifications
  SAFETY_TRANSLATION    // order: 99 - Safety + translation (DEPRECATED - will be split)
  SECURITY              // order: 98 - Security validation (blocks unsafe content)
  TRANSLATION           // order: 99 - Translation to customer language
  CUSTOM                // order: 1, 8-98 - Custom agents
}

enum SearchConversationState {
  ACTIVE      // Conversation is ongoing
  COMPLETED   // Customer finished successfully
  ABANDONED   // Customer left without completing
  EXPIRED     // Session expired (>10 min inactivity)
}

// ============================================
// 🕐 SCHEDULER JOB STATUS
// ============================================
// Tracks the last execution of each cron job
// ONE record per job (updated on each run, not a log)

model SchedulerJobStatus {
  id            String    @id @default(cuid())
  jobName       String    @unique  // "whatsapp-challenge-queue", "short-urls-cleanup", etc.
  lastRunAt     DateTime?          // Last execution timestamp
  lastStatus    String    @default("NEVER_RUN")  // "SUCCESS", "FAILED", "RUNNING", "NEVER_RUN"
  lastError     String?            // Error message if failed
  lastDuration  Int?               // Duration in milliseconds
  nextRunAt     DateTime?          // Calculated next run time
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("scheduler_job_status")
}
