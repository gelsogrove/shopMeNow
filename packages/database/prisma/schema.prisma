  createdAt         DateTime        @default(now())
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customers       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsAppQueue     WhatsAppQueue[] // Inverse relation for queue tracking

  @@index([conversationId, createdAt])
  @@index([workspaceId, customerId])
  @@index([createdAt])
  @@map("conversation_messages")
}

// SUBSCRIPTION & BILLING SYSTEM

enum PlanType {
  FREE_TRIAL // 14 days trial with €29 credit
  BASIC // €29/month - 1 channel, 50 products, 50 customers
  PREMIUM // €49/month - 2 channels, 100 products, 100 customers
  ENTERPRISE // Custom pricing - unlimited everything
}

// Feature 197: Subscription status for billing separation
enum SubscriptionStatus {
  ACTIVE // Normal operation - chatbot responds
  PAUSE_PENDING // User requested pause - effective next month
  PAUSED // Subscription paused - no billing, no chatbot
  PAYMENT_FAILED // Payment failed - chatbot blocked until payment
}

enum TransactionType {
  MESSAGE // -€0.10 per WhatsApp message
  NEW_ORDER // -€1.00 per order created
  PUSH_NOTIFICATION // -€1.00 per push notification
  RECHARGE // +€X credit recharge
  MONTHLY_FEE // -€29/€59 monthly subscription fee
  UPGRADE_FEE // Pro-rata fee when upgrading plan
  ADJUSTMENT // Manual adjustment by admin
  INITIAL_CREDIT // +€29 initial trial credit
  BONUS // +€X gift credit (not invoiced)
  INVOICE_PAID // Bank charge for monthly invoice (plan + usage) - does NOT affect credit
}

// Transaction history for billing - tracks all credit movements
// Feature 198: userId is primary key for billing (owner-based)
// workspaceId is optional for operation tracking (which channel was used)
model BillingTransaction {
  id            String          @id @default(cuid())
  userId        String // Owner who owns the credit
  workspaceId   String? // Optional: which workspace/channel originated the charge
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2) // Negative for charges, positive for credits
  balanceAfter  Decimal         @db.Decimal(10, 2) // Balance after this transaction
  description   String
  referenceId   String? // Order ID, message ID, etc.
  referenceType String? // "order", "message", "push", etc.
  metadata      Json? // Additional context
  createdAt     DateTime        @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([type])
  @@index([createdAt])
  @@map("billing_transactions")
}

model PayPalTransaction {
  id          String                  @id @default(cuid())
  userId      String
  invoiceId   String?
  amount      Decimal                 @db.Decimal(10, 2)
  currency    String                  @default("EUR")
  status      PayPalTransactionStatus
