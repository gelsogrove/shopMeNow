// Conversation Messages - Complete history for LLM Router context
model ConversationMessage {
  id                String          @id @default(cuid())
  workspaceId       String
  customerId        String
  conversationId    String
  role              String // "user", "assistant", "function", "system"
  content           String          @db.Text
