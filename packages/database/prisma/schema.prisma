  @@index([userId])
  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
  @@map("paypal_transactions")
}

// Feature 197: Monthly Invoice for billing tracking
// Tracks subscription fees + credit usage per month per owner
enum InvoiceStatus {
  DRAFT // Current month, still accumulating charges
  PENDING // Month ended, awaiting payment
  PAID // Successfully charged
  FAILED // Payment failed
  CANCELLED // Invoice cancelled (e.g., user deleted)
}

enum PayPalStatus {
  DISCONNECTED
  CONNECTED
}

enum PayPalTransactionStatus {
  SUCCESS
  FAILED
}

model MonthlyInvoice {
  id            String  @id @default(cuid())
  userId        String // Owner of the invoice (Feature 198)
  invoiceNumber String? @unique // Human-readable invoice number (e.g. INV-2026-01-0001)

  // Period
  periodStart DateTime // 1st of month 00:00:00
  periodEnd   DateTime // Last day of month 23:59:59
  periodMonth Int // Month (1-12)
  periodYear  Int // Year (e.g., 2025)

  // Amounts
  subscriptionAmount Decimal @db.Decimal(10, 2) // €19/€49/€99 monthly fee
  creditUsage        Decimal @db.Decimal(10, 2) // Total consumption from wallet
  creditDebt         Decimal @default(0) @db.Decimal(10, 2) // Negative balance carried over
  creditNotesTotal   Decimal @default(0) @db.Decimal(10, 2)
  subtotalAmount     Decimal @default(0) @db.Decimal(10, 2)
  taxRate            Decimal @default(0.22) @db.Decimal(5, 4)
  taxAmount          Decimal @default(0) @db.Decimal(10, 2)
  totalAmount        Decimal @db.Decimal(10, 2) // Total to charge

  // Status
  status              InvoiceStatus @default(DRAFT)
  paidAt              DateTime?
  paypalTransactionId String?
  adminNotes          String?
  adminMarkedById     String?
  adminMarkedAt       DateTime?

  // Metadata
  planType       PlanType // Plan during this period
  itemsBreakdown Json // { messages: 150, orders: 10, pushes: 5, ... }

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditNotes        InvoiceCreditNote[]
  adjustments        InvoiceAdjustment[]
  paypalTransactions PayPalTransaction[]

  @@unique([userId, periodYear, periodMonth])
  @@index([userId])
  @@index([status])
  @@index([periodYear, periodMonth])
  @@map("monthly_invoices")
}

model InvoiceAdjustment {
  id             String   @id @default(cuid())
  invoiceId      String
  userId         String
  amount         Decimal  @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?

  invoice MonthlyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([userId])
  @@map("invoice_adjustments")
}

model InvoiceCreditNote {
  id             String   @id @default(cuid())
  invoiceId      String
  userId         String
  amount         Decimal  @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?

  invoice MonthlyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([userId])
  @@map("invoice_credit_notes")
}

// Plan configuration - dynamic limits from database
model PlanConfiguration {
  id                  String   @id @default(cuid())
  planType            PlanType @unique
  displayName         String // "Free Trial", "Basic", "Premium", "Enterprise"
  monthlyFee          Decimal  @db.Decimal(10, 2)
  maxChannels         Int
  maxProducts         Int
  maxCustomers        Int
  maxTeamMembers      Int?     @map("max_team_members") // NULL = unlimited (for PREMIUM/ENTERPRISE)
  messageCost         Decimal  @db.Decimal(10, 2) // €0.10
  orderCost           Decimal  @db.Decimal(10, 2) // €1.00
  pushCost            Decimal  @db.Decimal(10, 2) // €1.00
  lowBalanceThreshold Decimal  @db.Decimal(10, 2) // €5.00
  trialDays           Int      @default(0) // 14 for FREE_TRIAL, 0 for others
  initialCredit       Decimal  @default(0) @db.Decimal(10, 2) // €19 for FREE_TRIAL
  features            Json? // Additional features list
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([planType])
  @@index([isActive])
  @@map("plan_configurations")
}

enum BillingType {
  MONTHLY_CHANNEL // €19.00 - Monthly subscription cost (LEGACY)
  MESSAGE // €0.15 - Per message/interaction cost (LLM responses) (LEGACY)
  NEW_CUSTOMER // €1.50 - New customer registration (LEGACY)
  NEW_ORDER // €1.50 - New order placed (LEGACY)
  PUSH_CAMPAIGN // €1.00 - Push notification (advertising campaigns) (LEGACY)
  FEEDBACK // No cost - Customer feedback
  ORDER_REVIEW // No cost - Order review
  CAMPAIGN_LINK // No cost - Campaign link click
  // NOTE: Legacy billing - use BillingTransaction for new billing system
}

enum CampaignFrequency {
  ONCE // Una sola volta (no ripetizione)
  WEEKLY // Ogni 7 giorni
  BIWEEKLY // Ogni 14 giorni
  MONTHLY // Ogni 30 giorni
  BIMONTHLY // Ogni 60 giorni
  QUARTERLY // Ogni 90 giorni
  SEMIANNUAL // Ogni 180 giorni (6 mesi)
  ANNUAL // Ogni 365 giorni
}

enum CampaignTargetType {
  ALL // Tutti i customer attivi del workspace
  SELECTED // Solo customer IDs specificati
}

// 🔔 Push Campaigns (v2)
enum PushCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum PushCampaignBillingStatus {
  PENDING
  PARTIAL
  BILLED
  FAILED
}

enum PushCampaignChannel {
  WHATSAPP
}

enum PushCampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Campaign {
  id             String            @id @default(cuid())
  workspaceId    String
  name           String // "Richiesta Feedback Semestrale"
  messagePreview String            @db.Text // Markdown per visualizzazione admin (con token [FEEDBACK], {{nome}}, ecc)
  frequency      CampaignFrequency
  isActive       Boolean           @default(true)

  // Destinatari
  targetType  CampaignTargetType @default(ALL)
  customerIds String[]           @default([]) // Array di customer IDs se targetType = SELECTED

  // Template WhatsApp (opzionale, per uso futuro con Meta Business API)
  templateName   String? // Nome template Meta (es: "feedback_request_v1")
  templateParams Json? // Parametri template WhatsApp come JSON

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastRunAt DateTime? // Ultima esecuzione cron

  // Relations
  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sends     CampaignSent[]
  feedbacks CustomerFeedback[]

  @@index([workspaceId])
  @@index([isActive])
  @@index([frequency])
}

model CampaignSent {
  id          String    @id @default(cuid())
  campaignId  String
  customerId  String
  workspaceId String
  sentAt      DateTime  @default(now())
  tokenUsed   String? // Token generato per tracking click
  clickedAt   DateTime? // Se customer ha cliccato sul link

  // Relations
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([customerId])
  @@index([workspaceId])
  @@index([sentAt])
}

model CustomerFeedback {
  id          String   @id @default(cuid())
  customerId  String
  workspaceId String
  campaignId  String? // Opzionale: da quale campagna arriva
  rating      Int // 1-5 stelline
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  customer  Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([workspaceId])
  @@index([campaignId])
  @@index([createdAt])
}

// 🚀 Push Campaigns v2 (promotional/scheduled sends)
model PushCampaign {
  id                 String                    @id @default(cuid())
  workspaceId        String
  createdByUserId    String?
  name               String
  status             PushCampaignStatus        @default(DRAFT)
  channel            PushCampaignChannel       @default(WHATSAPP)
  sendAt             DateTime?
  templateId         String?
  templateLocale     String?
  bodyPreview        String?                   @db.Text
  mediaUrl           String?
  expectedRecipients Int                       @default(0)
  actualSent         Int                       @default(0)
  actualFailed       Int                       @default(0)
  actualSkipped      Int                       @default(0)
  costPerMessage     Decimal                   @default(1.00) @db.Decimal(10, 2)
  billingStatus      PushCampaignBillingStatus @default(PENDING)
  throttlePerSecond  Int                       @default(10)
  batchSize          Int                       @default(50)
  lastError          String?                   @db.Text
  metadata           Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  workspace  Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User?                   @relation(fields: [createdByUserId], references: [id])
  recipients PushCampaignRecipient[]

  @@index([workspaceId])
  @@index([status])
  @@index([sendAt])
}

model PushCampaignRecipient {
  id            String                      @id @default(cuid())
  campaignId    String
  workspaceId   String
  customerId    String?
  phone         String
  status        PushCampaignRecipientStatus @default(PENDING)
  errorCode     String?
  errorMessage  String?                     @db.Text
  sentAt        DateTime?
  messageId     String?
  priceCharged  Decimal                     @default(0) @db.Decimal(10, 2)
  isBlacklisted Boolean                     @default(false)
  isBlocked     Boolean                     @default(false)
  isFake        Boolean                     @default(false)
  optOutAt      DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  campaign  PushCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customers?   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, phone])
  @@index([campaignId])
  @@index([workspaceId])
  @@index([status])
}

model AdminSession {
  id             String     @id @default(cuid())
  sessionId      String     @unique @db.VarChar(64)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  expiresAt      DateTime
  lastActivityAt DateTime   @default(now())
  ipAddress      String?    @db.VarChar(45)
  userAgent      String?    @db.Text
  isActive       Boolean    @default(true)

  @@index([sessionId])
  @@index([userId])
  @@index([expiresAt])
  @@index([isActive])
  @@map("admin_sessions")
}

// PLATFORM CONFIGURATION - Single Source of Truth for pricing & feature flags
model PlatformConfig {
  id            String     @id @default(cuid())
  type          ConfigType // PRICE, FLAG, or LIMIT
  key           String     @unique // e.g., "BASIC_MONTHLY", "canLogin", "MAX_PRODUCTS"
  value         String // The actual value (parsed as number/boolean at runtime)
  originalValue String? // Original value for strikethrough display (e.g., "29" when current is "19")
  description   String?    @db.Text // Human-readable description
  isActive      Boolean    @default(true) // Can be toggled without deleting
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([type])
  @@index([key])
  @@index([isActive])
  @@map("platform_config")
}

// Keep PricingConfig for backwards compatibility during migration
model PricingConfig {
  id          String      @id @default(cuid())
  type        PricingType // PLAN, USAGE, or THRESHOLD
  key         String      @unique // e.g., "BASIC_MONTHLY", "MESSAGE", "FREE_MESSAGES"
  value       Float // The actual price or threshold value
  description String?     @db.Text // Human-readable description
  isActive    Boolean     @default(true) // Can be toggled without deleting
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([key])
  @@index([isActive])
  @@map("pricing_config")
}

enum ConfigType {
  PRICE // Monetary values (€19, €0.10, etc.)
  FLAG // Boolean feature flags (canLogin, canRegister)
  LIMIT // Numeric limits (maxProducts, maxMessages)
}

enum PricingType {
  PLAN // Monthly subscription plans (€0, €29, €59, €199)
  USAGE // Per-action costs (€0.15/message, €1.50/customer, etc.)
  THRESHOLD // Free tier limits (200 messages, 50 products, etc.)
}

enum AgentType {
  ROUTER // order: 0 - Intent classification + FAQ
  OPERATOR // order: 0.5 - Human operator manual message
  PRODUCT_SEARCH // order: 2 - Product search specialist
  CART_MANAGEMENT // order: 3 - Cart operations
  ORDER_TRACKING // order: 4 - Order viewing
  CUSTOMER_SUPPORT // order: 5 - Support & escalation
  SUMMARY_AGENT // order: 5.5 - Conversation summarization
  PROFILE_MANAGEMENT // order: 6 - Profile modifications
  NOTIFICATIONS // order: 7 - Push notifications
  CONVERSATION_HISTORY // order: 8 - Humanization layer (saluti, contesto, offerte)
  SAFETY_TRANSLATION // order: 99 - Safety + translation (DEPRECATED - will be split)
  SECURITY // order: 98 - Security validation (blocks unsafe content)
  TRANSLATION // order: 99 - Translation to customer language
  CUSTOM // order: 1, 8-98 - Custom agents
}

enum SearchConversationState {
  ACTIVE // Conversation is ongoing
  COMPLETED // Customer finished successfully
  ABANDONED // Customer left without completing
  EXPIRED // Session expired (>10 min inactivity)
}

// 🕐 SCHEDULER JOB STATUS
// Tracks the last execution of each cron job
// ONE record per job (updated on each run, not a log)

model SchedulerJobStatus {
  id           String    @id @default(cuid())
  jobName      String    @unique // "whatsapp-channel-queue", "short-urls-cleanup", etc.
  isActive     Boolean   @default(true) // Manual enable/disable from backoffice
  lastRunAt    DateTime? // Last execution timestamp
  lastStatus   String    @default("NEVER_RUN") // "SUCCESS", "FAILED", "RUNNING", "NEVER_RUN", "SKIPPED"
  lastError    String? // Error message if failed
  lastDuration Int? // Duration in milliseconds
  nextRunAt    DateTime? // Calculated next run time
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("scheduler_job_status")
}

// 🗑️ SOFT DELETE AUDIT LOG - Tracks all hard-deletes for compliance
model SoftDeleteAuditLog {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType      String // "USER", "WORKSPACE", "CUSTOMER", "ORDER", "MESSAGE", etc.
  deletedIds      String[] // Array of IDs that were hard-deleted
  deletedIdCount  Int // Number of records deleted
  reason          String? // Admin reason or "SCHEDULED_CLEANUP"
  deletedByUserId String? // Admin who initiated delete (null for scheduler)
  deletedAt       DateTime  @default(now())

  @@index([workspaceId, deletedAt])
  @@index([deletedAt])
  @@map("soft_delete_audit_logs")
}

// ⚡ WORKSPACE CALLING FUNCTIONS - Controls which CFs are active per workspace
model WorkspaceCallingFunction {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  functionName String // camelCase function name: "addToCart", "contactOperator", etc.
  description  String? // Optional description override for this workspace
  isActive     Boolean   @default(true) // Toggle ON/OFF for this workspace
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, functionName]) // One record per function per workspace
  @@index([workspaceId, isActive])
  @@map("workspace_calling_functions")
}

// 📜 LEGAL DOCUMENTS - Dynamic multilingual legal pages
model LegalDocument {
  id        String   @id @default(cuid())
  type      String   @unique // "GDPR", "PRIVACY_POLICY", "TERMS_OF_SERVICE", "REFUND_POLICY"
  titleIt   String // Italian title
  titleEn   String // English title
  titleEs   String // Spanish title
  titlePt   String // Portuguese title
  contentIt String   @db.Text // Italian HTML content
  contentEn String   @db.Text // English HTML content
  contentEs String   @db.Text // Spanish HTML content
  contentPt String   @db.Text // Portuguese HTML content
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_documents")
}

// 🎫 SUPPORT TICKETS - Customer support system (User-based, workspace optional)
model SupportTicket {
  id          String              @id @default(cuid())
  ticketCode  String              @unique // Auto-generated: TKT-XXXXXX
  userId      String // Creator (User)
  workspaceId String? // Optional workspace for context (can be null)
  user        User                @relation(fields: [userId], references: [id])
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id])
  issueType   SupportIssueType
  subject     String
  status      SupportTicketStatus @default(PENDING)
  messages    SupportMessage[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  closedAt    DateTime?

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id          String              @id @default(cuid())
  ticketId    String
  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String // User ID (owner or admin)
  senderType  SupportSenderType // CUSTOMER or ADMIN
  content     String              @db.Text // Rich HTML content from WYSIWYG
  attachments SupportAttachment[]
  isRead      Boolean             @default(false)
  createdAt   DateTime            @default(now())

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
  @@map("support_messages")
}

model SupportAttachment {
  id         String         @id @default(cuid())
  messageId  String
  message    SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename   String
  url        String // S3 URL
  storageKey String // S3 key for cleanup
  mimeType   String
  size       Int // File size in bytes
  createdAt  DateTime       @default(now())

  @@index([messageId])
  @@map("support_attachments")
}

// Support Ticket Enums
enum SupportIssueType {
  ACCOUNT_ISSUE
  PLAN_AND_BILLING
  WHATSAPP
  WIDGET
  SALES_AGENT
  SUPPORT
  OTHER
}

enum SupportTicketStatus {
  PENDING
  IN_PROGRESS
  CLOSED
}

enum SupportSenderType {
  CUSTOMER
  ADMIN
}
