#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 🔒 PRE-COMMIT HOOK - BLOCCA COMMIT SE TEST FALLISCONO
# 
# Andrea: "voglio metterlo poi dentro il test prima di fare il merge a main"
#
# Questo hook BLOCCA il commit se:
# - ❌ ESLint errors
# - ❌ Prettier formatting errors  
# - ❌ Security tests falliscono
# - ❌ TypeScript compilation errors
#
# Solo se TUTTO passa → ✅ Commit permesso

echo "🔒 Running pre-commit checks..."
echo ""

# Run lint-staged (lint + format + security tests)
npx lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ PRE-COMMIT FAILED!"
  echo "🚨 Fix the errors above before committing"
  echo ""
  exit 1
fi

echo ""
echo "✅ All pre-commit checks passed!"
echo "✅ Commit allowed"
echo ""

exit 0
