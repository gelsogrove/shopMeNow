{
  "_principle": "Declarative display-state intermediate flows. Each entry intercepts the LLM when a customer-reported display token (after location/type/number capture) matches one of the documented incident codes. Phase A emits a one-shot guidance reply (replyKey from localization.ts) and marks state.activeFlowId. Phase B reads the next customer turn: resolvedRegex closes the case, persistFailureRegex (or alwaysEscalateOnNextTurn) escalates with escalationReason. Anti-hardcode rule: never add a TypeScript guard for a 'display X → guide → escalate' pattern; add a JSON entry here. Schema/validation lives in models/display-flow.ts and is enforced at boot in utils/runtime.ts.",
  "_schemaVersion": 1,
  "flows": [
    {
      "id": "al001-sequence-error",
      "displayMatches": ["AL001", "AL 001", "ALARM 001", "ALARM001", "ALARMA 001", "ALARMA001"],
      "requires": ["location", "machineType", "machineNumber"],
      "step": {
        "replyKey": "al001GuideRetry",
        "resolvedReplyKey": "al001Resolved"
      },
      "resolvedRegex": "(ya\\s+funciona|^funciona\\b|^ok\\s+resuelto|^resuelto\\b|^perfecto\\b|^perfetto\\b|gi[aà]\\s+funziona|ora\\s+funziona|ja\\s+funciona|ara\\s+(?:ja\\s+)?funciona|now\\s+(?:it\\s+)?works|(?:it\\s+)?works\\s+now|it'?s\\s+working|now\\s+working|^perfect\\b)",
      "persistFailureRegex": "(sigue\\s+(?:igual|sin\\s+(?:arrancar|funcionar|responder|empezar)|saliendo)|sigue\\s+(?:sin|igual)|no\\s+(?:responde|arranca|empieza|funciona|desaparece)|todav[ií]a\\s+(?:no|sale|sigue)|aun\\s+(?:no|sale|sigue)|el\\s+mensaje\\s+(?:sigue|no\\s+desaparece)|^(no|nada)\\b)",
      "reaskBeforeEscalate": true,
      "escalationReason": "AL001 sequence error — guidance did not resolve",
      "escalationReplyKey": "displayInstructionFailureEscalate"
    },
    {
      "id": "alm-door-blocked",
      "displayMatches": ["ALM/DOOR", "ALMDOOR"],
      "requires": ["location", "machineNumber"],
      "step": {
        "replyKey": "almDoorGuidance",
        "resolvedReplyKey": "al001Resolved"
      },
      "resolvedRegex": "(ya\\s+(?:funciona|no\\s+aparece)|^funciona\\b|^ok\\s+resuelto|^resuelto\\b|^perfecto\\b|^perfetto\\b|ha\\s+desaparecid|desaparecid|gi[aà]\\s+funziona|ora\\s+funziona|ja\\s+funciona|ara\\s+(?:ja\\s+)?funciona|ha\\s+desaparegut|now\\s+(?:it\\s+)?works|(?:it\\s+)?works\\s+now|it'?s\\s+working|^perfect\\b|gone|disappeared)",
      "persistFailureRegex": "(no\\s+desaparece|sigue\\s+(?:igual|sin\\s+arrancar|saliendo)|continua|todav[ií]a\\s+sale|aun\\s+sale|^(no|nope)\\b)",
      "escalationReason": "ALM DOOR — persists after retry"
    },
    {
      "id": "code-001-explained",
      "displayMatches": ["C001"],
      "requires": ["location"],
      "step": {
        "replyKey": "code001Explain",
        "alwaysEscalateOnNextTurn": true
      },
      "escalationReplyKey": "code001Escalate",
      "escalationReason": "Display 001 — always escalated"
    },
    {
      "id": "countdown-display",
      "displayMatches": ["120"],
      "requires": [],
      "step": {
        "replyKey": "countdownGuidance"
      },
      "resolvedRegex": "(ya\\s+termin[oó]|ha\\s+terminado|END|^end\\b|^fin\\b|^fatto\\b|^done\\b|^terminat\\b|ja\\s+ha\\s+acabat|j'ai\\s+fini|j[aà]\\s+(?:ha\\s+)?acabado)",
      "reaskBeforeEscalate": false,
      "escalationReason": null
    }
  ]
}
