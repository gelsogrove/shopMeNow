{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "skipLibCheck": true,
    "incremental": true,
    "outDir": "./dist/src",
    "sourceMap": true,
    "resolveJsonModule": true,
    "noEmitOnError": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/**/*", "prisma/data/defaultAgents.ts", "../../shared/**/*"],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts",
    "src/__tests__/**/*",
    "src/application/agents/CustomAgentLLM.ts",
    "src/application/agents/NotificationsAgentLLM.ts",
    "src/application/agents/OperatorAgentLLM.ts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "ignore": ["node_modules"],
    "compilerOptions": {
      "module": "commonjs",
      "strict": false,
      "skipLibCheck": true,
      "noImplicitAny": false,
      "strictNullChecks": false
    }
  }
}
