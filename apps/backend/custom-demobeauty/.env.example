# custom-demobeauty — environment template.
# Copy to .env and fill in. The module loads this file from its own folder.
# (Andrea manages the real .env — it is never committed.)

# Required: OpenRouter API key for the LLM.
OPENROUTER_API_KEY=

# Optional: operator/sede email for escalations and booking briefings.
OPERATOR_EMAIL=echatbotai@gmail.com

# Optional: Gmail SMTP for sending confirmation/escalation emails.
# Without these, emails are logged to console only (demo still works).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional overrides (defaults come from settings.json):
# PRIVACY_POLICY_URL=https://www.echatbot.ai/aviso-legal
# LLM_MODEL=anthropic/claude-haiku-4.5
