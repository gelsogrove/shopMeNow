{
  "name": "democasa-chatbot",
  "version": "0.1.0",
  "description": "DemoCasa chatbot — real-estate agency assistant, prompt-driven LLM with cached system prompt, session state, viewing/franchising appointments, valuation requests, escalation by email. Twin architecture of custom-demowash.",
  "type": "module",
  "scripts": {
    "demo": "node --import tsx agent.ts",
    "test": "node --import tsx agent.ts",
    "demo:local": "LLM_BASE_URL=${LLM_BASE_URL:-http://localhost:11434/v1} LLM_MODEL=${LLM_MODEL:-qwen3:14b} OPENROUTER_API_KEY=ollama node --import tsx agent.ts --local",
    "demo:contract": "node --import tsx test-contract.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
