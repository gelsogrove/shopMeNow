{
  "name": "@echatbot/scheduler",
  "version": "1.0.0",
  "description": "eChatbot Scheduler - Background cron jobs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsnd --respawn src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop echatbot-scheduler",
    "restart": "pm2 restart echatbot-scheduler",
    "logs": "pm2 logs echatbot-scheduler",
    "test": "dotenv -e ../../.env -- jest --passWithNoTests"
  },
  "author": "Andrea Gelso",
  "license": "ISC",
  "dependencies": {
    "@echatbot/database": "*",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "pm2": "^6.0.13",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.16",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "dotenv-cli": "^7.3.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
