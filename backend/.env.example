# Database
DATABASE_URL="postgresql://username:password@localhost:5432/shopmefy"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="24h"

# Token Configuration
# Duration for secure tokens (orders, profile, checkout links sent via WhatsApp)
# Format: "1h" for 1 hour, "30m" for 30 minutes, "2h" for 2 hours
TOKEN_EXPIRATION="1h"

# Admin User
ADMIN_EMAIL="admin@shopme.com"
ADMIN_PASSWORD="venezia44"

# Frontend URL
FRONTEND_URL="http://localhost:5173"

# Email Configuration (SMTP)
# For Gmail: smtp.gmail.com, port 587, secure false
# For production, use your SMTP provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@shopme.com"

# Development: Leave SMTP credentials empty to use test account
# The system will auto-create Ethereal test account for development

# OpenRouter API
OPENROUTER_API_KEY="your-openrouter-api-key"

# ============================================
# 🆕 WHATSAPP BUSINESS API INTEGRATION
# ============================================
# 
# IMPORTANTE: Le credenziali WhatsApp specifiche per workspace (API Key, Phone Number)
# sono salvate nel DATABASE per ogni workspace tramite l'interfaccia Workspace Settings.
# 
# Queste ENV sono SOLO per configurazione globale del sistema:

# WhatsApp Business API URL (Meta/Facebook Graph API v18.0)
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"

# Token di verifica webhook (creane uno random sicuro, min 20 caratteri)
# Usato da Meta per verificare il tuo webhook durante il setup iniziale
WHATSAPP_VERIFY_TOKEN="your-secure-random-verify-token-min-20-chars"

# App Secret da Meta/Facebook Developer Dashboard
# CRITICO: Usato per verificare firma HMAC dei webhook (sicurezza!)
# Trovalo in: Meta App Dashboard > App Settings > Basic > App Secret
WHATSAPP_APP_SECRET="your-whatsapp-app-secret-from-meta-dashboard"

# Webhook Security (PRODUZIONE: SEMPRE true!)
WHATSAPP_WEBHOOK_ENABLED="true"
WHATSAPP_SIGNATURE_VERIFICATION="true"

# Rate Limiting (messaggi per minuto)
WHATSAPP_MAX_MESSAGES_PER_MINUTE_WORKSPACE="100"
WHATSAPP_MAX_MESSAGES_PER_MINUTE_CUSTOMER="10"

# Retry Configuration
WHATSAPP_MAX_RETRY_ATTEMPTS="3"
WHATSAPP_RETRY_DELAY_MS="1000"

# N8N (legacy - può essere rimosso se non usato)
N8N_WEBHOOK_URL="http://localhost:5678/webhook/whatsapp"

# Server
PORT="3001"
NODE_ENV="development"