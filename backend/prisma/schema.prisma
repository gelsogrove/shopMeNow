generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Billing {
  id            String      @id
  workspaceId   String
  customerId    String?
  amount        Float
  type          BillingType
  description   String
  userQuery     String?
  previousTotal Float       @default(0)
  currentCharge Float       @default(0)
  newTotal      Float       @default(0)
  createdAt     DateTime    @default(now())
  customers     customers?  @relation(fields: [customerId], references: [id])
  Workspace     Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([createdAt])
  @@index([customerId])
  @@index([type])
  @@index([workspaceId])
}

model Campaign {
  id               String             @id
  workspaceId      String
  name             String
  messagePreview   String
  frequency        CampaignFrequency
  isActive         Boolean            @default(true)
  targetType       CampaignTargetType @default(ALL)
  customerIds      String[]           @default([])
  templateName     String?
  templateParams   Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  lastRunAt        DateTime?
  Workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  CampaignSent     CampaignSent[]
  CustomerFeedback CustomerFeedback[]

  @@index([frequency])
  @@index([isActive])
  @@index([workspaceId])
}

model CampaignSent {
  id          String    @id
  campaignId  String
  customerId  String
  workspaceId String
  sentAt      DateTime  @default(now())
  tokenUsed   String?
  clickedAt   DateTime?
  Campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customers   customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([customerId])
  @@index([sentAt])
  @@index([workspaceId])
}

model CustomerFeedback {
  id          String    @id
  customerId  String
  workspaceId String
  campaignId  String?
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())
  Campaign    Campaign? @relation(fields: [campaignId], references: [id])
  customers   customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt])
  @@index([customerId])
  @@index([workspaceId])
}

model Language {
  id        String   @id
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Prompts {
  id          String     @id
  name        String
  content     String
  workspaceId String
  isRouter    Boolean    @default(false)
  department  String?
  temperature Float?     @default(0.7)
  top_p       Float?     @default(0.9)
  top_k       Int?       @default(40)
  model       String?    @default("GPT-4.1-mini")
  max_tokens  Int?       @default(1000)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  isActive    Boolean    @default(true)
  Workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    messages[]

  @@index([workspaceId])
}

model ShortUrls {
  id             String    @id
  shortCode      String    @unique @db.VarChar(10)
  originalUrl    String
  workspaceId    String
  clicks         Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([shortCode])
  @@index([workspaceId])
}

model UserWorkspace {
  userId      String
  workspaceId String
  role        String
  users       users     @relation(fields: [userId], references: [id])
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@id([userId, workspaceId])
}

model Workspace {
  id                        String             @id
  name                      String
  slug                      String             @unique
  whatsappPhoneNumber       String?
  whatsappApiKey            String?
  notificationEmail         String?
  webhookUrl                String?
  isActive                  Boolean            @default(true)
  language                  String             @default("ENG")
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime
  isDelete                  Boolean            @default(false)
  currency                  String             @default("EUR")
  challengeStatus           Boolean            @default(false)
  description               String?
  messageLimit              Int                @default(50)
  blocklist                 String?            @default("")
  url                       String?
  businessType              BusinessType       @default(ECOMMERCE)
  welcomeMessages           Json?              @default("{\"en\": \"Welcome!\", \"es\": \"¡Bienvenido!\", \"it\": \"Benvenuto!\"}")
  wipMessages               Json?              @default("{\"en\": \"Work in progress. Please contact us later.\", \"es\": \"Trabajos en curso. Por favor, contáctenos más tarde.\", \"it\": \"Lavori in corso. Contattaci più tardi.\", \"pt\": \"Em manutenção. Por favor, contacte-nos mais tarde.\"}")
  afterRegistrationMessages Json?              @default("{\"de\": \"Danke für Ihre Registrierung, [nome]! Wie kann ich Ihnen heute helfen? Möchten Sie Ihre Bestellungen sehen? Die Angebote? Oder benötigen Sie andere Informationen?\", \"en\": \"Thank you for registering, [nome]! How can I help you today? Would you like to see your orders? The offers? Or do you need other information?\", \"es\": \"¡Gracias por registrarte, [nome]! ¿Cómo puedo ayudarte hoy? ¿Quieres ver tus pedidos? ¿Las ofertas? ¿O necesitas otra información?\", \"fr\": \"Merci de vous être inscrit, [nome] ! Comment puis-je vous aider aujourd'hui ? Voulez-vous voir vos commandes ? Les offres ? Ou avez-vous besoin d'autres informations ?\", \"it\": \"Grazie per esserti registrato, [nome]! Come ti posso aiutare oggi? Vuoi vedere i tuoi ordini? Le offerte? O hai bisogno di altre informazioni?\", \"pt\": \"Obrigado por se registrar, [nome]! Como posso ajudá-lo hoje? Quer ver seus pedidos? As ofertas? Ou precisa de outras informações?\"}")
  debugMode                 Boolean            @default(true)
  apiKey                    String?
  apiSecret                 String?
  metadata                  Json?
  Billing                   Billing[]
  Campaign                  Campaign[]
  Prompts                   Prompts[]
  ShortUrls                 ShortUrls[]
  UserWorkspace             UserWorkspace[]
  admin_sessions            admin_sessions[]
  agent_configs             agent_configs[]
  carts                     carts[]
  categories                categories[]
  chat_sessions             chat_sessions[]
  customers                 customers[]
  documents                 documents[]
  faqs                      faqs[]
  gdpr_content              gdpr_content?
  languages                 languages[]
  offers                    offers[]
  orders                    orders[]
  products                  products[]
  sales                     sales[]
  secure_tokens             secure_tokens[]
  services                  services[]
  usage                     usage[]
  whatsapp_settings         whatsapp_settings?
}

model admin_sessions {
  id             String     @id
  sessionId      String     @unique @db.VarChar(64)
  userId         String
  workspaceId    String?
  createdAt      DateTime   @default(now())
  expiresAt      DateTime
  lastActivityAt DateTime   @default(now())
  ipAddress      String?    @db.VarChar(45)
  userAgent      String?
  isActive       Boolean    @default(true)
  users          users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([isActive])
  @@index([sessionId])
  @@index([userId])
}

model agent_configs {
  id          String    @id
  workspaceId String
  prompt      String    @default("You are a helpful assistant.")
  model       String    @default("openai/gpt-4o-mini")
  temperature Float     @default(0.7)
  maxTokens   Int       @default(1000)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model cart_items {
  id        String    @id
  itemType  ItemType  @default(PRODUCT)
  quantity  Int
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  cartId    String
  productId String?
  serviceId String?
  carts     carts     @relation(fields: [cartId], references: [id])
  products  products? @relation(fields: [productId], references: [id])
  services  services? @relation(fields: [serviceId], references: [id])
}

model carts {
  id          String       @id
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  customerId  String       @unique
  workspaceId String
  cart_items  cart_items[]
  customers   customers    @relation(fields: [customerId], references: [id])
  Workspace   Workspace    @relation(fields: [workspaceId], references: [id])
}

model categories {
  id                                   String     @id
  name                                 String
  description                          String?
  createdAt                            DateTime   @default(now())
  updatedAt                            DateTime
  isActive                             Boolean    @default(true)
  workspaceId                          String
  slug                                 String
  Workspace                            Workspace  @relation(fields: [workspaceId], references: [id])
  offers_offers_categoryIdTocategories offers[]   @relation("offers_categoryIdTocategories")
  products                             products[]
  offers_OfferCategories               offers[]   @relation("OfferCategories")

  @@unique([slug, workspaceId])
}

model chat_sessions {
  id          String     @id
  status      String     @default("active")
  context     Json?      @default("{}")
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  workspaceId String
  customerId  String
  customers   customers  @relation(fields: [customerId], references: [id])
  Workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  messages    messages[]
}

model customers {
  id                            String             @id
  name                          String
  email                         String
  phone                         String?
  address                       String?
  company                       String?
  discount                      Float?             @default(0)
  language                      String?            @default("ENG")
  currency                      String?            @default("EUR")
  notes                         String?
  serviceIds                    String[]           @default([])
  isBlacklisted                 Boolean            @default(false)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime
  isActive                      Boolean            @default(true)
  workspaceId                   String
  last_privacy_version_accepted String?
  privacy_accepted_at           DateTime?
  push_notifications_consent    Boolean            @default(false)
  push_notifications_consent_at DateTime?
  activeChatbot                 Boolean            @default(true)
  invoiceAddress                Json?
  salesId                       String?
  Billing                       Billing[]
  CampaignSent                  CampaignSent[]
  CustomerFeedback              CustomerFeedback[]
  carts                         carts?
  chat_sessions                 chat_sessions[]
  sales                         sales?             @relation(fields: [salesId], references: [id])
  Workspace                     Workspace          @relation(fields: [workspaceId], references: [id])
  orders                        orders[]
  usage                         usage[]
}

model document_chunks {
  id         String    @id
  documentId String
  content    String
  chunkIndex Int
  embedding  Json?
  createdAt  DateTime  @default(now())
  documents  documents @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([chunkIndex])
  @@index([documentId])
}

model documents {
  id              String            @id
  filename        String
  originalName    String
  filePath        String
  fileSize        Int
  mimeType        String
  status          DocumentStatus    @default(UPLOADED)
  workspaceId     String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  isActive        Boolean           @default(true)
  document_chunks document_chunks[]
  Workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([status])
  @@index([workspaceId])
}

model faq_chunks {
  id         String   @id
  faqId      String
  content    String
  chunkIndex Int
  embedding  Json?
  createdAt  DateTime @default(now())
  faqs       faqs     @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@index([chunkIndex])
  @@index([faqId])
}

model faqs {
  id          String       @id
  question    String
  answer      String
  isActive    Boolean      @default(true)
  workspaceId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  faq_chunks  faq_chunks[]
  Workspace   Workspace    @relation(fields: [workspaceId], references: [id])
}

model gdpr_content {
  id          String    @id
  workspaceId String    @unique
  content     String
  version     String    @default("1.0")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model languages {
  id          String    @id
  name        String
  code        String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  isActive    Boolean   @default(true)
  workspaceId String
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model messages {
  id                 String           @id
  direction          MessageDirection
  content            String
  type               MessageType      @default(TEXT)
  status             String           @default("sent")
  aiGenerated        Boolean          @default(false)
  metadata           Json?            @default("{}")
  read               Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime
  chatSessionId      String
  promptId           String?
  functionCallsDebug String?
  processingSource   String?
  translatedQuery    String?
  processedPrompt    String?
  debugInfo          String?
  whatsappStatus     String?
  whatsappError      String?
  whatsappMessageId  String?
  sentBy             String?
  chat_sessions      chat_sessions    @relation(fields: [chatSessionId], references: [id])
  Prompts            Prompts?         @relation(fields: [promptId], references: [id])

  @@index([sentBy])
  @@index([whatsappMessageId])
  @@index([whatsappStatus])
}

model offers {
  id                                       String       @id
  name                                     String
  description                              String?
  discountPercent                          Float
  startDate                                DateTime
  endDate                                  DateTime
  isActive                                 Boolean      @default(true)
  categoryId                               String?
  workspaceId                              String
  createdAt                                DateTime     @default(now())
  updatedAt                                DateTime
  categories_offers_categoryIdTocategories categories?  @relation("offers_categoryIdTocategories", fields: [categoryId], references: [id])
  Workspace                                Workspace    @relation(fields: [workspaceId], references: [id])
  categories_OfferCategories               categories[] @relation("OfferCategories")
}

model order_items {
  id             String    @id
  itemType       ItemType  @default(PRODUCT)
  quantity       Int       @default(1)
  unitPrice      Float
  totalPrice     Float
  productVariant Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  orderId        String
  productId      String?
  serviceId      String?
  orders         orders    @relation(fields: [orderId], references: [id])
  products       products? @relation(fields: [productId], references: [id])
  services       services? @relation(fields: [serviceId], references: [id])
}

model orders {
  id              String           @id
  orderCode       String           @unique
  status          OrderStatus      @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus?   @default(PENDING)
  totalAmount     Float
  shippingAmount  Float?           @default(0)
  taxAmount       Float?           @default(0)
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  discountCode    String?
  discountAmount  Float?           @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  customerId      String
  workspaceId     String
  trackingNumber  String?
  order_items     order_items[]
  customers       customers        @relation(fields: [customerId], references: [id])
  Workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  payment_details payment_details?
}

model otp_tokens {
  id        String    @id
  userId    String
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  users     users     @relation(fields: [userId], references: [id])
}

model password_resets {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  users     users     @relation(fields: [userId], references: [id])
}

model payment_details {
  id               String   @id
  provider         String
  status           String   @default("PENDING")
  amount           Float
  currency         String   @default("EUR")
  providerResponse Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  orderId          String   @unique
  orders           orders   @relation(fields: [orderId], references: [id])
}

model product_chunks {
  id          String   @id
  productId   String
  content     String
  chunkIndex  Int
  embedding   Json?
  workspaceId String
  language    String   @default("en")
  createdAt   DateTime @default(now())
  products    products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([chunkIndex])
  @@index([language])
  @@index([productId])
  @@index([workspaceId])
}

model products {
  id             String           @id
  name           String
  ProductCode    String?
  description    String?
  formato        String?
  price          Float
  stock          Int              @default(0)
  sku            String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  isActive       Boolean          @default(true)
  workspaceId    String
  categoryId     String?
  slug           String           @unique
  status         ProductStatus    @default(ACTIVE)
  imageUrl       String[]         @default([])
  cart_items     cart_items[]
  order_items    order_items[]
  product_chunks product_chunks[]
  categories     categories?      @relation(fields: [categoryId], references: [id])
  Workspace      Workspace        @relation(fields: [workspaceId], references: [id])
}

model registration_attempts {
  id            String   @id
  phoneNumber   String
  workspaceId   String
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime @default(now())
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@unique([phoneNumber, workspaceId])
}

model registration_tokens {
  id          String    @id
  token       String    @unique
  phoneNumber String
  workspaceId String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model sales {
  id          String      @id
  firstName   String
  lastName    String
  email       String
  phone       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  isActive    Boolean     @default(true)
  workspaceId String
  customers   customers[]
  Workspace   Workspace   @relation(fields: [workspaceId], references: [id])
}

model secure_tokens {
  id          String    @id
  token       String    @unique
  type        String
  workspaceId String
  userId      String?
  phoneNumber String?
  payload     Json?
  expiresAt   DateTime
  usedAt      DateTime?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  customerId  String?
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([customerId, type, workspaceId], map: "unique_customer_token_non_null")
  @@index([customerId])
  @@index([expiresAt])
  @@index([token])
  @@index([workspaceId])
}

model service_chunks {
  id         String   @id
  serviceId  String
  content    String
  chunkIndex Int
  embedding  Json?
  createdAt  DateTime @default(now())
  services   services @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([chunkIndex])
  @@index([serviceId])
}

model services {
  id             String           @id
  code           String           @unique
  name           String
  description    String
  price          Float
  currency       String           @default("EUR")
  isActive       Boolean          @default(true)
  workspaceId    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  duration       Int              @default(60)
  imageUrl       String[]         @default([])
  cart_items     cart_items[]
  order_items    order_items[]
  service_chunks service_chunks[]
  Workspace      Workspace        @relation(fields: [workspaceId], references: [id])
}

model usage {
  id          String    @id
  workspaceId String
  clientId    String
  price       Float     @default(0.005)
  createdAt   DateTime  @default(now())
  customers   customers @relation(fields: [clientId], references: [id])
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([clientId])
  @@index([createdAt])
  @@index([workspaceId])
}

model users {
  id              String            @id
  email           String            @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  status          UserStatus        @default(ACTIVE)
  lastLogin       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  role            UserRole          @default(MEMBER)
  twoFactorSecret String?
  gdprAccepted    DateTime?
  phoneNumber     String?
  UserWorkspace   UserWorkspace[]
  admin_sessions  admin_sessions[]
  otp_tokens      otp_tokens[]
  password_resets password_resets[]
}

model whatsapp_settings {
  id          String    @id
  phoneNumber String    @unique
  apiKey      String
  webhookUrl  String?
  settings    Json?     @default("{}")
  adminEmail  String?
  smtpHost    String?   @default("smtp.ethereal.email")
  smtpPort    Int?      @default(587)
  smtpSecure  Boolean?  @default(false)
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  workspaceId String    @unique
  gdpr        String?
  Workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

enum BillingType {
  MONTHLY_CHANNEL
  MESSAGE
  NEW_CUSTOMER
  NEW_ORDER
  HUMAN_SUPPORT
  PUSH_MESSAGE
  NEW_FAQ
  ACTIVE_OFFER
  FEEDBACK
  ORDER_REVIEW
  CAMPAIGN_LINK
}

enum BusinessType {
  ECOMMERCE
  RESTAURANT
  CLINIC
  RETAIL
  SERVICES
  GENERIC
}

enum CampaignFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum CampaignTargetType {
  ALL
  SELECTED
}

enum ChannelType {
  WHATSAPP
  TELEGRAM
  MESSENGER
  LINE
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  ERROR
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  LOCATION
  CONTACT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  PAYPAL
  CASH_ON_DELIVERY
  CRYPTO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_PAID
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  OUT_OF_STOCK
}

enum UserRole {
  ADMIN
  OWNER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
