{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for Italian products shop",
  "main": "src/index.ts",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "dev": "dotenv -c .env -- tsnd --respawn src/index.ts",
    "dev:ollama": "node scripts/start-ollama.js & dotenv -c .env -- tsnd --respawn src/index.ts",
    "ollama:start": "node scripts/start-ollama.js",
    "ollama:check": "node scripts/start-ollama.js",
    "build": "prisma generate && tsc",
    "start": "node dist/src/index.js",
    "seed": "ts-node prisma/seed.ts",
    "seed:update": "ts-node scripts/export-db-to-seed.ts",
    "db:export": "echo '⚠️  WARNING: This will OVERWRITE data files AND export prompts!' && ts-node scripts/export-db-to-seed.ts",
    "db:backup": "ts-node scripts/backup-database.ts",
    "db:backup-data": "cp -r prisma/data prisma/data-backup-$(date +%Y%m%d_%H%M%S) && echo '✅ Data backup created'",
    "db:restore": "ts-node scripts/restore-database.ts",
    "update-pricing": "ts-node scripts/update-pricing.ts",
    "update:prompts": "node scripts/update-prompts.js",
    "update:all-prompts": "ts-node scripts/update-all-agent-prompts.ts",
    "quick-seed": "ts-node scripts/quick-seed.ts",
    "view-pricing": "ts-node scripts/view-pricing.ts",
    "start:prod": "node dist/src/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --notify false --clear --exit-child -r dotenv/config src/index.ts",
    "scheduler": "ts-node-dev --respawn --transpile-only -r dotenv/config src/scheduler.ts",
    "mcp:start": "cd mcp && node mcp-server.js",
    "mcp:test": "cd mcp && node mcp-test-client.js",
    "test": "npm run test:unit && npm run test:security",
    "test:all": "npm run test:unit && npm run test:security && npm run test:integration",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.config.unit.js --passWithNoTests",
    "test:security": "cross-env NODE_ENV=test INTEGRATION_TEST=true jest --config jest.config.security.js",
    "test:integration": "cross-env NODE_ENV=test INTEGRATION_TEST=true jest --testPathPattern=integration --passWithNoTests",
    "test:coverage": "cross-env NODE_ENV=test jest --verbose --coverage --coverageReporters='text-summary' --coverageReporters='html' --config jest.config.unit.js",
    "lint": "echo 'Linting skipped for development'",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "cd .. && husky install backend/.husky"
  },
  "keywords": [
    "ecommerce",
    "italian",
    "products",
    "shop"
  ],
  "author": "Andrea Gelso",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "openai": "^4.98.0",
    "pdfkit": "^0.17.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axios": "^1.11.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.57.1",
    "fs-extra": "^11.3.2",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.6.2",
    "prisma": "^6.5.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
