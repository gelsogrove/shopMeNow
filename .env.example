# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║                         ECHATBOT ENVIRONMENT CONFIGURATION                       ║
# ╠═══════════════════════════════════════════════════════════════════════════════╣
# ║  Organized by team responsibility. Only REQUIRED variables need to be set.    ║
# ║  Security settings are HARDCODED in src/config/security.config.ts             ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════════
# 🖥️  DEVOPS / INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════════════════════
# Team: DevOps
# When: During server setup and deployment
# ───────────────────────────────────────────────────────────────────────────────

# Server Configuration
NODE_ENV="development"                    # "development" | "production"
PORT="3001"                               # Backend API port

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:pass@localhost:5432/echatbotfy"

# Frontend URL (for CORS and email links)
FRONTEND_URL="http://localhost:5173"      # Production: https://app.echatbot.io

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY / AUTH TEAM
# ═══════════════════════════════════════════════════════════════════════════════
# Team: Security
# When: Initial setup, keep these SECRET!
# ───────────────────────────────────────────────────────────────────────────────

# JWT Token (generate with: openssl rand -hex 64)
JWT_SECRET="your-64-char-hex-secret"      # REQUIRED: Auth won't work without it!

# Secure Token Expiration (WhatsApp links: orders, profile, checkout)
TOKEN_EXPIRATION="1h"                     # "15m" | "30m" | "1h" | "2h" | "24h"

# Initial Admin User (created on first seed)
ADMIN_EMAIL="admin@echatbot.ai"
ADMIN_PASSWORD="SecurePassword123!"       # CHANGE THIS in production!

# ⚠️  SECURITY DEFAULTS ARE HARDCODED (not configurable via env):
#     See src/config/security.config.ts for:
#     - Rate Limiting: 5 login/15min, 3 2FA/15min
#     - Account Lockout: 5 failures → 30 min lock
#     - Password Policy: 8+ chars, upper/lower/number/special

# ═══════════════════════════════════════════════════════════════════════════════
# 🔑 OAUTH PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════════
# Team: Security / Product
# When: Setting up social login
# ───────────────────────────────────────────────────────────────────────────────

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Facebook Login (https://developers.facebook.com/apps) - OPTIONAL
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Apple Sign In (https://developer.apple.com) - OPTIONAL
APPLE_SERVICE_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY_PATH=""

# ═══════════════════════════════════════════════════════════════════════════════
# 📧 EMAIL / NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════
# Team: Product / DevOps
# When: Setting up transactional emails
# ───────────────────────────────────────────────────────────────────────────────

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"                # Gmail, SendGrid, SES, etc.
SMTP_PORT="465"                           # 587 (TLS) or 465 (SSL)
SMTP_SECURE="true"                        # "true" for SSL, "false" for TLS
SMTP_USER="noreply@yourcompany.com"
SMTP_PASS="your-app-password"             # For Gmail: use App Password
SMTP_FROM="eChatbot <noreply@yourcompany.com>"

# Development: Leave empty to auto-create Ethereal test account

# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 AI / LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Team: AI / Product
# When: Configuring chatbot and AI features
# ───────────────────────────────────────────────────────────────────────────────

# OpenRouter (Cloud)
OPENROUTER_API_KEY="sk-or-v1-xxx"         # Get from openrouter.ai

# Model selection is done in Agent Settings UI (per workspace)
# Recommended: anthropic/claude-3.5-sonnet, openai/gpt-4o-mini

# ═══════════════════════════════════════════════════════════════════════════════
# 📦 STORAGE / FILE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════
# Team: DevOps
# When: Production deployment (Heroku uses Bucketeer addon)
# ───────────────────────────────────────────────────────────────────────────────

# Storage Configuration (Auto-switches: Local in dev, S3 in production)
# Development: Files saved in ./uploads/ folder
# Production: Files saved in S3-compatible storage (Bucketeer on Heroku)

# S3-Compatible Storage (Bucketeer addon on Heroku provides these automatically)
# On Heroku: heroku addons:create bucketeer:micro
# Then copy: BUCKETEER_AWS_ACCESS_KEY_ID → AWS_ACCESS_KEY_ID
AWS_ACCESS_KEY_ID=""                      # From Bucketeer addon (or AWS if using direct S3)
AWS_SECRET_ACCESS_KEY=""                  # From Bucketeer addon (or AWS if using direct S3)
AWS_REGION="us-east-1"                    # Bucketeer default: us-east-1
AWS_S3_BUCKET=""                          # From BUCKETEER_BUCKET_NAME (e.g., bucketeer-xxx-xxx)

# Local Storage (Development only)
UPLOADS_DIR="./uploads"                   # Local folder for dev uploads
UPLOADS_URL="http://localhost:3001/uploads" # Public URL for dev uploads

# ═══════════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 OPTIONAL / NICE-TO-HAVE
# ═══════════════════════════════════════════════════════════════════════════════

# Default avatar when user has no profile picture
DEFAULT_AVATAR_URL="https://ui-avatars.com/api/?name={initials}&background=10b981&color=fff&size=200"
