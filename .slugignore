# Heroku Slugignore - Files to exclude from deployment
# Reduces slug size and speeds up deployment

# Tests
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/jest.config.js
**/vitest.config.ts

# Development files
*.md
docs/
terraform/
scripts/
.github/
.vscode/

# Source files (BUILD on Heroku, so we NEED them!)
# ✅ KEEP all src/ folders - Heroku compiles on server
# apps/backend/src/
# apps/frontend/src/
# apps/scheduler/src/
# apps/backoffice/src/

# TypeScript config (KEEP - needed for Heroku build)
# **/tsconfig.json  # ✅ KEEP: required for tsc compilation on Heroku
# **/tsconfig.*.json

# Local development
docker-compose.yml
.env.example
.env.backup.*

# ✅ Keep runtime prompt assets used by defaultAgents
!docs/prompts/**
!apps/backend/src/templates/shared/**

# Logs
**/logs/
*.log

# Git files
.git/
.gitignore
