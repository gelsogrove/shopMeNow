#!/bin/bash
# Heroku release script
# Skip release for backoffice (static SPA - no DB needed)

if [ "$HEROKU_APP_NAME" = "echatbot-backoffice" ] || [ "$HEROKU_APP_NAME" = "echatbot-scheduler" ]; then
  echo "✅ ${HEROKU_APP_NAME}: Skipping release (no DB migrations)"
  exit 0
fi

# Run migrations for apps that need DB
echo "🚀 Running Prisma migrations..."
npm run prisma:migrate:prod
