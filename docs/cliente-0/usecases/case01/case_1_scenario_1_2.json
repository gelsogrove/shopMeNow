{
  "case": 1,
  "scenario": 1.2,
  "name": "Case 1 — Escalation Path",
  "description": "Cliente intenta seleccionar programa pero la lavadora sigue sin arrancar. El chatbot pide el nombre del usuario y escala el caso al operador con un resumen.",
  "turns": [
    "Hola, la lavadora no funciona",
    "pone PUSH PROG",
    "Goya",
    "5",
    "no arranca",
    "se ha bloqueada la pantalla",
    "Carlos"
  ],
  "assertions": [
    {
      "turn": 1,
      "includes": ["hola", "pantalla"],
      "excludes": ["programa", "presiona", "pulsa", "reinicia", "hello", "what appears", "machine"]
    },
    {
      "turn": 2,
      "includes": ["lavander"],
      "excludes": ["laundry", "self-service"]
    },
    {
      "turn": 3,
      "includes": ["numero", "lavadora"],
      "excludes": ["number", "washing machine"]
    },
    {
      "turn": 4,
      "includes": ["programa"],
      "excludes": ["program button", "press a", "wash"]
    },
    {
      "turn": 6,
      "includes": ["llamas"],
      "excludes": ["perfecto", "resuelto"]
    },
    {
      "turn": 7,
      "includes": ["operador", "brevedad", "llamada"],
      "excludes": ["perfecto", "resuelto"]
    }
  ],
  "expectedOutcome": "ESCALATED",
  "notes": "El chatbot escala después de que el programa no resuelve el problema. Pide el nombre antes de escalar y hace un resumen del caso."
}
