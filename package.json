{
  "name": "echatbot",
  "version": "1.0.0",
  "private": true,
  "description": "eChatbot - WhatsApp E-commerce Platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npx kill-port 3000 3001 ; npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm run dev -w @echatbot/backend",
    "dev:frontend": "npm run dev -w @echatbot/frontend",
    "dev:scheduler": "npm run dev -w @echatbot/scheduler",
    "dev:backoffice": "npm run dev -w @echatbot/backoffice",
    "kill-ports": "./scripts/kill-ports.sh",
    "dev:all": "npm run kill-ports && npm run dev:backend & npm run dev:frontend & npm run dev:scheduler & npm run dev:backoffice",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build -w @echatbot/backend",
    "build:seed": "npm run build:seed -w @echatbot/database",
    "heroku-postbuild": "npm run prisma:generate && echo '✅ Using pre-compiled seed from repo'",
    "start": "npm run start:all",
    "start:all": "node apps/backend/dist/src/index.js",
    "start:backend": "npm run start -w @echatbot/backend",
    "start:scheduler": "npm run start -w @echatbot/scheduler",
    "prod:backend": "npm run start:pm2 -w @echatbot/backend",
    "prod:scheduler": "npm run start:pm2 -w @echatbot/scheduler",
    "prod:all": "npm run prod:backend && npm run prod:scheduler",
    "prisma:generate": "npm run generate -w @echatbot/database",
    "prisma:migrate": "npm run migrate:dev -w @echatbot/database",
    "prisma:migrate:prod": "npm run migrate:deploy -w @echatbot/database",
    "prisma:seed": "npm run seed -w @echatbot/database",
    "prisma:seed:production": "npm run seed:production -w @echatbot/database",
    "prisma:studio": "npm run studio -w @echatbot/database",
    "update:prompts": "npm run update:prompts -w @echatbot/database",
    "prisma:reset": "npm run migrate:reset -w @echatbot/database",
    "prisma:check:env": "npm run check:env -w @echatbot/database",
    "test": "run-s test:be test:fe test:scheduler test:backoffice test:db",
    "test:all": "npm run test",
    "test:be": "npm run test -w @echatbot/backend",
    "test:fe": "npm run test -w @echatbot/frontend",
    "test:scheduler": "npm run test -w @echatbot/scheduler",
    "test:backoffice": "npm run test -w @echatbot/backoffice",
    "test:db": "npm run test -w @echatbot/database",
    "test:unit": "npm run test:unit -w @echatbot/backend",
    "test:security": "npm run test:security -w @echatbot/backend",
    "test:coverage": "npm run test:coverage -w @echatbot/backend",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "author": "Andrea Gelso",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.952.0",
    "@aws-sdk/s3-request-presigner": "^3.952.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "pdfkit": "^0.17.2",
    "react-is": "^19.2.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.4",
    "npm-run-all2": "^8.0.4",
    "rollup": "^4.54.0"
  }
}
