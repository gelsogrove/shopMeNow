{
  "name": "echatbot",
  "version": "1.0.0",
  "private": true,
  "description": "eChatbot - WhatsApp E-commerce Platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "echo '⚠️  WARNING: Running without scheduler! Use npm run dev:all for full setup' && npx kill-port 3000 3001 ; npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm run dev -w @echatbot/backend",
    "dev:frontend": "npm run dev -w @echatbot/frontend",
    "dev:scheduler": "npm run dev -w @echatbot/scheduler",
    "dev:backoffice": "npm run dev -w @echatbot/backoffice",
    "kill-ports": "./scripts/kill-ports.sh",
    "dev:all": "npm run kill-ports && npm run dev:backend & npm run dev:frontend & npm run dev:scheduler & npm run dev:backoffice",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "cd apps/backend && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:backoffice": "npm run build -w @echatbot/backoffice",
    "build:scheduler": "npm run build -w @echatbot/scheduler",
    "heroku-postbuild": "if [ \"$HEROKU_APP_NAME\" = \"echatbot-scheduler\" ]; then npm run heroku:scheduler; elif [ \"$HEROKU_APP_NAME\" = \"echatbot-backoffice\" ]; then npm run heroku:backoffice; else npm run heroku:app; fi",
    "heroku:app": "npm run prisma:generate && npm run prisma:migrate:prod && npm run build -w @echatbot/database && npm run build:backend && npm run build:frontend && npm run build:backoffice && echo '✅ echatbot-app: Database + Backend + Frontend + Backoffice built'",
    "heroku:scheduler": "cp Procfile.scheduler Procfile && npm run prisma:generate && npm run prisma:migrate:prod && npm run build -w @echatbot/database && cd shared && npx tsc translation-prompts.ts --outDir ../apps/scheduler/dist/shared --declaration --declarationMap --sourceMap --module commonjs --target ES2020 --esModuleInterop --skipLibCheck && cd .. && npm run build:scheduler && echo '✅ echatbot-scheduler: Database + Shared + Scheduler built'",
    "heroku:backoffice": "cp Procfile.backoffice Procfile && npm run prisma:generate && npm run build:backoffice && echo '✅ echatbot-backoffice: Backoffice built'",
    "start": "npm run start:all",
    "start:all": "node apps/backend/dist/src/index.js",
    "start:backend": "npm run start -w @echatbot/backend",
    "start:scheduler": "npm run start -w @echatbot/scheduler",
    "prod:backend": "npm run start:pm2 -w @echatbot/backend",
    "prod:scheduler": "npm run start:pm2 -w @echatbot/scheduler",
    "prod:all": "npm run prod:backend && npm run prod:scheduler",
    "prisma:generate": "npm run generate -w @echatbot/database",
    "prisma:migrate": "npm run migrate:dev -w @echatbot/database",
    "prisma:migrate:prod": "npm run migrate:deploy -w @echatbot/database",
    "prisma:seed": "npm run seed -w @echatbot/database",
    "prisma:seed:production": "npm run seed:production -w @echatbot/database",
    "prisma:studio": "npm run studio -w @echatbot/database",
    "update:prompts": "npm run update:prompts -w @echatbot/database",
    "clear:audio:cloudinary": "npm run clear:audio:cloudinary -w @echatbot/backend",
    "prisma:reset": "npm run migrate:reset -w @echatbot/database",
    "prisma:check:env": "npm run check:env -w @echatbot/database",
    "test": "run-s test:be test:fe test:scheduler test:backoffice test:db",
    "test:all": "npm run test",
    "test:be": "npm run test -w @echatbot/backend",
    "test:fe": "npm run test -w @echatbot/frontend",
    "test:scheduler": "npm run test -w @echatbot/scheduler",
    "test:backoffice": "npm run test -w @echatbot/backoffice",
    "test:db": "npm run test -w @echatbot/database",
    "test:unit": "npm run test:unit -w @echatbot/backend",
    "test:security": "npm run test:security -w @echatbot/backend",
    "test:coverage": "npm run test:coverage -w @echatbot/backend",
    "publish": "./scripts/deploy-all-heroku.sh",
    "deploy:heroku": "./scripts/deploy-all-heroku.sh",
    "setup:heroku": "./scripts/heroku-setup.sh",
    "log:heroku": "heroku logs --tail --app echatbot-app",
    "log:heroku:app": "heroku logs --tail --app echatbot-app",
    "log:heroku:webhook": "heroku logs --tail --app echatbot-app | grep -iE 'webhook|whatsapp|📱|incoming.*message|ultramsg'",
    "log:heroku:scheduler": "heroku logs --tail --app echatbot-scheduler",
    "log:heroku:backoffice": "heroku logs --tail --app echatbot-backoffice",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "author": "Andrea Gelso",
  "license": "ISC",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "pdfkit": "^0.17.2",
    "react-is": "^19.2.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.4",
    "npm-run-all2": "^8.0.4",
    "rollup": "^4.54.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-android-arm-eabi": "^4.54.0",
    "@rollup/rollup-android-arm64": "^4.54.0",
    "@rollup/rollup-darwin-x64": "^4.54.0",
    "@rollup/rollup-freebsd-arm64": "^4.54.0",
    "@rollup/rollup-freebsd-x64": "^4.54.0",
    "@rollup/rollup-linux-arm-gnueabihf": "^4.54.0",
    "@rollup/rollup-linux-arm-musleabihf": "^4.54.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.54.0",
    "@rollup/rollup-linux-arm64-musl": "^4.54.0",
    "@rollup/rollup-linux-loong64-gnu": "^4.54.0",
    "@rollup/rollup-linux-ppc64-gnu": "^4.54.0",
    "@rollup/rollup-linux-riscv64-gnu": "^4.54.0",
    "@rollup/rollup-linux-riscv64-musl": "^4.54.0",
    "@rollup/rollup-linux-s390x-gnu": "^4.54.0",
    "@rollup/rollup-linux-x64-gnu": "^4.54.0",
    "@rollup/rollup-linux-x64-musl": "^4.54.0",
    "@rollup/rollup-openharmony-arm64": "^4.54.0",
    "@rollup/rollup-win32-arm64-msvc": "^4.54.0",
    "@rollup/rollup-win32-ia32-msvc": "^4.54.0",
    "@rollup/rollup-win32-x64-gnu": "^4.54.0",
    "@rollup/rollup-win32-x64-msvc": "^4.54.0",
    "ajv": "^8.18.0",
    "axios": "^1.13.6",
    "basic-ftp": "^5.2.0",
    "diff": "^7.0.0",
    "lodash-es": "4.17.23",
    "minimatch": "^10.2.4",
    "quill": "2.0.3",
    "quill-delta": "5.1.0",
    "rollup": "^4.60.0",
    "socket.io-parser": "^4.2.6",
    "systeminformation": "^5.31.5",
    "tmux": "^1.0.0",
    "undici": "^7.24.5"
  }
}
