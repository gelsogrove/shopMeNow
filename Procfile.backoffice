# 🔐 ECHATBOT-BACKOFFICE - Admin Panel SPA + Scheduler Worker
# Deploy: git push heroku-backoffice main
# Web: Backoffice static SPA (/)
# Worker: Scheduler cron jobs (background)
# API calls: CORS to echatbot-app

web: npx serve -s apps/backoffice/dist -l $PORT
worker: node apps/backoffice/scheduler-dist/src/index.js
